@prefix : <http://ontology.eil.utoronto.ca/HPCDM/> .
@prefix WV: <http://www.wurvoc.org/vocabularies/WV/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix hp: <http://ontology.eil.utoronto.ca/HPCDM/> .
@prefix ns: <http://creativecommons.org/ns#> .
@prefix oz: <http://www.theworldavatar.com/ontology/ontozoning/OntoZoning.owl#> .
@prefix cdt: <http://ontology.eil.utoronto.ca/CDT#> .
@prefix obs: <http://www.theworldavatar.com/ontology/ontobuildablespace/OntoBuildableSpace.owl#> .
@prefix opr: <http://www.theworldavatar.com/ontology/ontoplanningregulation/OntoPlanningRegulation.owl#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix Code: <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Code/> .
@prefix Prov: <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Prov/> .
@prefix Time: <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Time/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix gcih: <http://ontology.eil.utoronto.ca/GCI/Health/GCI-Health.owl#> .
@prefix gcir: <http://ontology.eil.utoronto.ca/GCI/Recreation/GCI-Recreation.owl#> .
@prefix om-1: <http://www.wurvoc.org/vocabularies/om-1.8/> .
@prefix om-2: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix Change: <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Change/> .
@prefix Change1: <http://ontology.eil.utoronto.ca/5087/5087/1/Change/> .
@prefix Building: <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Building/> .
@prefix Contract: <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Contract/> .
@prefix CityUnits: <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/CityUnits/> .
@prefix Household: <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Household/> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix TransInfra: <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/TransportationInfrastructure/> .
@prefix CityResident: <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/CityResident/> .
@prefix RecurringEvent: <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/RecurringEvent/> .
@prefix RecurringEvent2: <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/RecurringEvent/#> .
@base <http://ontology.eil.utoronto.ca/HPCDM/> .

<http://ontology.eil.utoronto.ca/HPCDM/> rdf:type owl:Ontology ;
                                          owl:imports <http://ontology.eil.utoronto.ca/5087/5087-1.owl> ,
                                                      <http://ontology.eil.utoronto.ca/5087/5087-2.owl> ,
                                                      <http://ontology.eil.utoronto.ca/census/cacensus.owl> ,
                                                      <http://www.theworldavatar.com/ontology/ontoplanningregulation/OntoPlanningRegulation.owl> ,
                                                      <http://www.theworldavatar.com/ontology/ontozoning/OntoZoning.owl> ;
                                          dc:creator "Megan Katsumi" ;
                                          terms:title "Housing Potential Common Data Model" .

#################################################################
#    Object Properties
#################################################################

###  http://ontology.eil.utoronto.ca/5087/2/LandUse/hasLandUse
<http://ontology.eil.utoronto.ca/5087/2/LandUse/hasLandUse> rdf:type owl:ObjectProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/administrativeAreaProperty
hp:administrativeAreaProperty rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf hp:hpcdmObjectProperty ;
                              rdfs:comment "Not a property in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/allowsUse
hp:allowsUse rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf hp:zoningProperty ;
             rdfs:comment "Note: this is distinct from oz:allowsUse which is restricted to defining land use for zoning types." .


###  http://ontology.eil.utoronto.ca/HPCDM/appliesTo
hp:appliesTo rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf hp:zoningProperty ;
             owl:propertyChainAxiom ( opr:forZoningType
                                      hp:zoningTypeDesignatedBy
                                      hp:definedFor
                                    ) .


###  http://ontology.eil.utoronto.ca/HPCDM/buildingProperty
hp:buildingProperty rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:hpcdmObjectProperty ;
                    rdfs:comment "Not a property in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/constrains
hp:constrains rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf hp:quantityConstraintProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/createdFromLot
hp:createdFromLot rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf hp:administrativeAreaProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/definedAtTime
hp:definedAtTime rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf hp:quantityConstraintProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/definedFor
hp:definedFor rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf hp:appliesTo ;
              rdfs:comment "Identifies the area that a regulation applies to. This may be defined directly in the regulation, or indirectly e.g. via the zoning type applied to an area (and regulations defined for the zoning type)." .


###  http://ontology.eil.utoronto.ca/HPCDM/definedForTime
hp:definedForTime rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf hp:quantityConstraintProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/definedIn
hp:definedIn rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf hp:informationArtifactProperty ;
             owl:propertyChainAxiom ( hp:definedIn
                                      <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/properPartOf>
                                    ) .


###  http://ontology.eil.utoronto.ca/HPCDM/definedInPlan
hp:definedInPlan rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf hp:definedIn .


###  http://ontology.eil.utoronto.ca/HPCDM/definesRegulation
hp:definesRegulation rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf hp:zoningProperty ;
                     owl:inverseOf hp:regulationDefinedIn ;
                     owl:propertyChainAxiom ( <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/hasProperPart>
                                              hp:definesRegulation
                                            ) .


###  http://ontology.eil.utoronto.ca/HPCDM/definesZoningException
hp:definesZoningException rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf hp:zoningProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/definesZoningType
hp:definesZoningType rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf hp:zoningProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/designatesZoningType
hp:designatesZoningType rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf hp:zoningProperty ;
                        owl:inverseOf hp:zoningTypeDesignatedBy .


###  http://ontology.eil.utoronto.ca/HPCDM/doesNotAllowUse
hp:doesNotAllowUse rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf hp:zoningProperty ;
                   rdfs:comment "Note: this is distinct from oz:allowsUse which is restricted to defining land use for zoning types." .


###  http://ontology.eil.utoronto.ca/HPCDM/environmentalRiskProperty
hp:environmentalRiskProperty rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf hp:hpcdmObjectProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/forLandUse
hp:forLandUse rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf hp:zoningProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/forLocation
hp:forLocation rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf hp:quantityProperty ;
               rdfs:domain om-1:Quantity .


###  http://ontology.eil.utoronto.ca/HPCDM/forWatershed
hp:forWatershed rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf hp:environmentalRiskProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/has
hp:has rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf hp:hpcdmObjectProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasArea
hp:hasArea rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf hp:administrativeAreaProperty ,
                              hp:has ,
                              <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/LandUse/hasArea> ;
           rdfs:label "area" .


###  http://ontology.eil.utoronto.ca/HPCDM/hasCondition
hp:hasCondition rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf hp:buildingProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasDevelopmentClassification
hp:hasDevelopmentClassification rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf hp:administrativeAreaProperty ,
                                                   hp:has .


###  http://ontology.eil.utoronto.ca/HPCDM/hasFSI
hp:hasFSI rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf hp:administrativeAreaProperty ,
                             hp:has ;
          rdfs:label "floor space index (FSI)" .


###  http://ontology.eil.utoronto.ca/HPCDM/hasFloorArea
hp:hasFloorArea rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf hp:buildingProperty ,
                                   hp:has ;
                rdfs:label "floor area" .


###  http://ontology.eil.utoronto.ca/HPCDM/hasFootprintArea
hp:hasFootprintArea rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:buildingProperty ,
                                       hp:has ;
                    rdfs:label "footprint area" .


###  http://ontology.eil.utoronto.ca/HPCDM/hasFrontage
hp:hasFrontage rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf hp:administrativeAreaProperty ,
                                  hp:has ;
               rdfs:label "frontage" .


###  http://ontology.eil.utoronto.ca/HPCDM/hasHeight
hp:hasHeight rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf hp:buildingProperty ,
                                hp:has ;
             rdfs:label "height" .


###  http://ontology.eil.utoronto.ca/HPCDM/hasImpact
hp:hasImpact rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf hp:environmentalRiskProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasMaxUseQuantum
hp:hasMaxUseQuantum rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:zoningProperty ;
                    rdfs:comment "Note that this property is distinct from (a generalization of) oz:hasMaxUseQuantum, as the OntoZoning property applies only to related LandUse to Use Quantums. The hpcdm:hasMaxUseQuantum may be used to define use quantums for other objects such as zoning types." .


###  http://ontology.eil.utoronto.ca/HPCDM/hasMinUseQuantum
hp:hasMinUseQuantum rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:zoningProperty ;
                    rdfs:comment "Note that this property is distinct from (a generalization of) oz:hasMinUseQuantum, as the OntoZoning property applies only to related LandUse to Use Quantums. The hpcdm:hasMinUseQuantum may be used to define use quantums for other objects such as zoning types." .


###  http://ontology.eil.utoronto.ca/HPCDM/hasPerimeter
hp:hasPerimeter rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf hp:administrativeAreaProperty ,
                                   hp:has ;
                rdfs:label "perimeter" .


###  http://ontology.eil.utoronto.ca/HPCDM/hasPlannedCapacity
hp:hasPlannedCapacity rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf hp:serviceAccessProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasResource
hp:hasResource rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf hp:serviceAccessProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasRiskFactor
hp:hasRiskFactor rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf hp:environmentalRiskProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasServiceRadius
hp:hasServiceRadius rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:serviceAccessProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasSetbacck
hp:hasSetbacck rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf hp:buildingProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasSubService
hp:hasSubService rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf hp:serviceAccessProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasZone
hp:hasZone rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf hp:zoningProperty ;
           owl:propertyChainAxiom ( [ owl:inverseOf hp:definedFor
                                    ]
                                    hp:designatesZoningType
                                  ) ;
           rdfs:comment "The zoning pattern also introduces the property hasZone for the AdministrativeArea class. This property is similar to the oz:hasZone property defined in the OZ ontology, however the OZ property is restricted to the OZ classes oz:Plot and oz:ZoningType and so cannot be reused here. The hasZone property defined in the HPCDM may be defined and inferred through object property chaining, based on the existence of Regulations establishing the zoning types." .


###  http://ontology.eil.utoronto.ca/HPCDM/hpcdmObjectProperty
hp:hpcdmObjectProperty rdf:type owl:ObjectProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/includesLandUse
hp:includesLandUse rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf hp:administrativeAreaProperty ;
                   rdf:type owl:TransitiveProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/influencesImpact
hp:influencesImpact rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:environmentalRiskProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/informationArtifactProperty
hp:informationArtifactProperty rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf hp:hpcdmObjectProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/maximumOf
hp:maximumOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf hp:quantityConstraintProperty ,
                                <http://ontology.eil.utoronto.ca/ISO21972/iso21972#description_of> .


###  http://ontology.eil.utoronto.ca/HPCDM/mayAllowUse
hp:mayAllowUse rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf hp:zoningProperty ;
               rdfs:comment "Note: this is distinct from oz:allowsUse which is restricted to defining land use for zoning types." .


###  http://ontology.eil.utoronto.ca/HPCDM/minDistanceToWater
hp:minDistanceToWater rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf hp:environmentalRiskProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/minimumOf
hp:minimumOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf hp:quantityConstraintProperty ,
                                <http://ontology.eil.utoronto.ca/ISO21972/iso21972#description_of> .


###  http://ontology.eil.utoronto.ca/HPCDM/occupiedBy
hp:occupiedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf hp:buildingProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/occupies
hp:occupies rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf hp:buildingProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/onPopulation
hp:onPopulation rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf hp:quantityConstraintProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/ownership
hp:ownership rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf hp:administrativeAreaProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/proposedFor
hp:proposedFor rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf hp:informationArtifactProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/providedFromSite
hp:providedFromSite rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:serviceAccessProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/providedToParcel
hp:providedToParcel rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:serviceAccessProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/quantityConstraintProperty
hp:quantityConstraintProperty rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf hp:hpcdmObjectProperty ;
                              rdfs:comment "Not a property in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/quantityProperty
hp:quantityProperty rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hp:hpcdmObjectProperty ;
                    rdfs:comment "Not a property in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/regulationDefinedIn
hp:regulationDefinedIn rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf hp:definedIn ,
                                          hp:zoningProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/serviceAccessProperty
hp:serviceAccessProperty rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf hp:hpcdmObjectProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/servicedBy
hp:servicedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf hp:serviceAccessProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/specifiesConstraint
hp:specifiesConstraint rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf hp:zoningProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/specifiesMaximumFor
hp:specifiesMaximumFor rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf hp:constrains .


###  http://ontology.eil.utoronto.ca/HPCDM/specifiesMinimumFor
hp:specifiesMinimumFor rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf hp:constrains .


###  http://ontology.eil.utoronto.ca/HPCDM/specifiesValueFor
hp:specifiesValueFor rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf hp:constrains .


###  http://ontology.eil.utoronto.ca/HPCDM/subZoningType
hp:subZoningType rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf hp:zoningProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/zonedAsType
hp:zonedAsType rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf hp:zoningProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/zonedForConstraint
hp:zonedForConstraint rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf hp:zoningProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/zoningProperty
hp:zoningProperty rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf hp:hpcdmObjectProperty ;
                  rdfs:comment "Not a property in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/zoningTypeDesignatedBy
hp:zoningTypeDesignatedBy rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf hp:zoningProperty .


###  http://www.wurvoc.org/vocabularies/om-1.8/unit_of_measure
om-1:unit_of_measure rdf:type owl:ObjectProperty .


###  https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/hasProperPart
<https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/hasProperPart> rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://ontology.eil.utoronto.ca/HPCDM/HPCDMDataProperty
hp:HPCDMDataProperty rdf:type owl:DatatypeProperty .


###  http://ontology.eil.utoronto.ca/HPCDM/hasNumberOfRooms
hp:hasNumberOfRooms rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf hp:HPCDMDataProperty .


###  http://www.wurvoc.org/vocabularies/om-1.8/numerical_value
om-1:numerical_value rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://ontology.eil.utoronto.ca/5087/2/LandUse/LandArea
<http://ontology.eil.utoronto.ca/5087/2/LandUse/LandArea> rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/CDT#HospitalEmergencyService
cdt:HospitalEmergencyService rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/CDT#LibraryService
cdt:LibraryService rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/CDT#LibrarySite
cdt:LibrarySite rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/CDT#TransitStop
cdt:TransitStop rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/GCI/Foundation/GCI-Foundation-v2.owl#GCIRatioQuantity
<http://ontology.eil.utoronto.ca/GCI/Foundation/GCI-Foundation-v2.owl#GCIRatioQuantity> rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/GCI/Health/GCI-Health.owl#HospitalBed
gcih:HospitalBed rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/GCI/ISO37120/FireEmergency.owl#10.1_FullTime_FireFighter_OperationalStaff
<http://ontology.eil.utoronto.ca/GCI/ISO37120/FireEmergency.owl#10.1_FullTime_FireFighter_OperationalStaff> rdf:type owl:Class ;
                                                                                                            rdfs:subClassOf hp:FireEmergencyServiceAccessThing .


###  http://ontology.eil.utoronto.ca/GCI/Recreation/GCI-Recreation.owl#Park
gcir:Park rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/HPCDM/AdministrativeArea
hp:AdministrativeArea rdf:type owl:Class ;
                      rdfs:subClassOf hp:AdministrativeAreaThing ,
                                      <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/City/JurisdictionalArea> ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/partOf> ;
                                        owl:someValuesFrom <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/LandUse/LandArea>
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:hasArea ;
                                        owl:allValuesFrom CityUnits:Area
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:hasDevelopmentClassification ;
                                        owl:allValuesFrom hp:LandDevelopmentClassification
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:hasFSI ;
                                        owl:allValuesFrom hp:FloorSpaceIndex
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:hasFrontage ;
                                        owl:allValuesFrom hp:Frontage
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:hasPerimeter ;
                                        owl:allValuesFrom CityUnits:Length
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:hasZone ;
                                        owl:allValuesFrom hp:ZoningType
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:servicedBy ;
                                        owl:allValuesFrom hp:Service
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:zonedAsType ;
                                        owl:allValuesFrom hp:ZoningType
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:zonedForConstraint ;
                                        owl:allValuesFrom hp:QuantityConstraint
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/hasLocation> ;
                                        owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/LandUse/landUse> ;
                                        owl:allValuesFrom hp:LandUse
                                      ] ;
                      rdfs:comment "AdministrativeArea is a specialization of 5087-2:LandArea that defines properties and subclasses that are relevant for housing potential." .


###  http://ontology.eil.utoronto.ca/HPCDM/AdministrativeAreaThing
hp:AdministrativeAreaThing rdf:type owl:Class ;
                           rdfs:subClassOf hp:HPCDMThing ;
                           rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableElectricalCapacity
hp:AvailableElectricalCapacity rdf:type owl:Class ;
                               rdfs:subClassOf hp:ElectricServiceCapacity ,
                                               om-1:Quantity ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty hp:forLocation ;
                                                 owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                 owl:hasValue hp:kilovolt_ampere
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass hp:ElectricalLoadCapacity
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass hp:ElectricLoad
                                               ] ;
                               rdfs:comment "a specialization of ElectricServiceCapacity and a i72:Quantity. The available electrical load capacity specifies the amount of electricity available to be delivered to an area (i.e., based on the capacity and what’s currently being used). It is a subclass of DifferenceQuantity as it can be defined as the difference between the electrical load capacity and the peak electrical load." ;
                               rdfs:label "Available load capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableEmergencyBedPopulationRatio
hp:AvailableEmergencyBedPopulationRatio rdf:type owl:Class ;
                                        rdfs:subClassOf hp:EmergencyCareServiceCapacity ,
                                                        hp:MedicalServiceAccessThing ,
                                                        hp:QuantityConstraint ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                          owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_cardinality_unit>
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass hp:EmergencyBedPopulationRatio
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass hp:MinEmergencyBedPopulationRatio
                                                        ] ;
                                        rdfs:comment "a type of QuantityConstraint that identifies the available beds per capita (i.e., before reaching the minimum acceptable rate). It is defined as the difference between the EmergencyBedPopulationRatio and the MinEmergencyBedPopulationRatio." ;
                                        rdfs:label "Surplus beds per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableFirefightersPerPopulation
hp:AvailableFirefightersPerPopulation rdf:type owl:Class ;
                                      rdfs:subClassOf hp:EmergencyServicesCapacity ,
                                                      hp:QuantityConstraint ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty hp:forLocation ;
                                                        owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                        owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass hp:FirefightersPerPopulation
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass hp:MinFirefightersPerPopulation
                                                      ] ;
                                      rdfs:comment "is a kind of QuantityConstraint that represents the available capacity of the service, as the difference between the capacity and the capacity in use. In other words, what change to the service use is possible without exceeding its defined capacity?" ;
                                      rdfs:label "Surplus firefighters per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableHospitalBedPopulationRatio
hp:AvailableHospitalBedPopulationRatio rdf:type owl:Class ;
                                       rdfs:subClassOf hp:HospitalServiceCapacity ,
                                                       hp:MedicalServiceAccessThing ,
                                                       hp:QuantityConstraint ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                         owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass hp:HospitalBedPopulationRatio
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass hp:MinHospitalBedPopulationRatio
                                                       ] ;
                                       rdfs:comment "a type of DifferenceConstraint that identifies the available beds per capita (i.e., before reaching the minimum acceptable rate)." ;
                                       rdfs:label "Surplus beds per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableLibraryPopulationRatio
hp:AvailableLibraryPopulationRatio rdf:type owl:Class ;
                                   rdfs:subClassOf hp:LibraryServiceAccessThing ,
                                                   hp:LibraryServiceCapacity ,
                                                   hp:QuantityConstraint ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                     owl:hasValue hp:square_metre_per_person
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onClass hp:LibraryAreaPopulationRatio
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onClass hp:MinLibraryAreaPopulationRatio
                                                   ] ;
                                   rdfs:comment "a QuantityConstraint that represents the maximum possible decrease in LibraryAreaPopulationRatio while maintaining an acceptable capacity use. It is calculated based on the difference between the LibraryAreaPopulationRatio and the MinLibraryAreaPopulationRatio." ;
                                   rdfs:label "Surplus library floor area per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailablePassengerThroughputRate
hp:AvailablePassengerThroughputRate rdf:type owl:Class ;
                                    rdfs:subClassOf hp:DifferenceQuantity ,
                                                    hp:TransitAccessThing ,
                                                    hp:TransitCapacity ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty hp:forLocation ;
                                                      owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass hp:PassengerThroughputRate
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass hp:MinPassengerThroughputRate
                                                    ] ;
                                    rdfs:comment "A DifferenceQuantity that specifies the difference between the PassengerThroughputRate and the MinPassengerThroughputRate as an indication of the available capacity of the service." ;
                                    rdfs:label "Unused passenger throughput capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableRecreationAreaPopulationRatio
hp:AvailableRecreationAreaPopulationRatio rdf:type owl:Class ;
                                          rdfs:subClassOf hp:ParkServiceAccessThing ,
                                                          hp:ParkServiceCapacity ,
                                                          hp:QuantityConstraint ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                            owl:hasValue hp:square_metre_per_person
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass hp:RecreationAreaPopulationRatio
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass hp:MinRecreationAreaPopulationRatio
                                                          ] ;
                                          rdfs:comment "a QuantityConstraint that represents the maximum possible change to the RecreationAreaPopulationRatio before violating the defined capacity. A difference between RecreationAreaPopulationRatio and MinRecreationAreaPopulationRatio." ;
                                          rdfs:label "Surplus park area per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableSupermarketsPopulationRatio
hp:AvailableSupermarketsPopulationRatio rdf:type owl:Class ;
                                        rdfs:subClassOf hp:FoodServiceAccessThing ,
                                                        hp:QuantityConstraint ,
                                                        hp:SupermarketServiceCapacity ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                          owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass hp:SupermarketsPopulationRatio
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass hp:MinSupermarketsPopulationRatio
                                                        ] ;
                                        rdfs:comment "a QuantityConstraint that is calculated based on the difference between the SupermarketsPopulationRatio and the MinSupermarketsPopulationRatio." ;
                                        rdfs:label "Surplus number of supermarkets per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableVehicleThroughputRate
hp:AvailableVehicleThroughputRate rdf:type owl:Class ;
                                  rdfs:subClassOf hp:DifferenceQuantity ,
                                                  hp:TransportationCapacity ,
                                                  hp:TransportationServiceAccessThing ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty hp:forLocation ;
                                                    owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass hp:MaxVehicleThroughputRate
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass hp:VehicleThroughputRate
                                                  ] ;
                                  rdfs:comment "a kind of TransportationCapacity. It is a DifferenceQuantity that specifies the difference between the VehicleThroughputRate and the MaxVehicleThroughputRate as an indication of the available capacity of the service." ;
                                  rdfs:label "Unused vehicle throughput capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableWasteProcessingRate
hp:AvailableWasteProcessingRate rdf:type owl:Class ;
                                rdfs:subClassOf hp:DifferenceQuantity ,
                                                hp:SolidWasteServiceCapacity ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty hp:forLocation ;
                                                  owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass hp:MaxWasteProcessingRate
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass hp:WasteProcessingRate
                                                ] ;
                                rdfs:comment "a type of SolidWasteServiceCapacity. This Quantity indicates the surplus waste processing capacity (if any). It is the difference between the corresponding values of the MaxWasteProcessingRate and the WasteProcessingRate for a service." ;
                                rdfs:label "Unused waste processing capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableWaterDistributionRate
hp:AvailableWaterDistributionRate rdf:type owl:Class ;
                                  rdfs:subClassOf hp:DifferenceQuantity ,
                                                  hp:WaterDistributionCapacity ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty hp:forLocation ;
                                                    owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass hp:MaxWaterDistributionRate
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass hp:WaterDistributionRate
                                                  ] ;
                                  rdfs:comment "a type of WaterDistributionCapacity. It is a DifferenceQuantity that represents the water distribution rate that is “available”, i.e., how much more water may be distributed until the system is at its capacity." ;
                                  rdfs:label "Unused distribution capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/AvailableWaterProcessingRate
hp:AvailableWaterProcessingRate rdf:type owl:Class ;
                                rdfs:subClassOf hp:DifferenceQuantity ,
                                                hp:WastewaterServiceCapacity ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty hp:forLocation ;
                                                  owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass hp:MaxWaterProcessingRate
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass hp:WaterProcessingRate
                                                ] ;
                                rdfs:comment "a DifferenceQuantity that identifies the waste processing rate that is available in the system. It is defined as the difference between the MaxWaterProcessingRate and the WaterProcessingRate." ;
                                rdfs:label "Unused processing capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/Building
hp:Building rdf:type owl:Class ;
            rdfs:subClassOf hp:BuildingThing ,
                            Building:Building ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:hasCondition ;
                              owl:allValuesFrom hp:BuildingCondition
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:hasFloorArea ;
                              owl:allValuesFrom hp:FloorArea
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:hasFootprintArea ;
                              owl:allValuesFrom hp:BuildingFootprintArea
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:hasHeight ;
                              owl:allValuesFrom hp:BuildingHeight
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:hasSetbacck ;
                              owl:allValuesFrom hp:BuildingSetback
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:occupiedBy ;
                              owl:allValuesFrom [ rdf:type owl:Class ;
                                                  owl:unionOf ( <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Organization/Organization>
                                                                <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Person/Person>
                                                              )
                                                ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:occupies ;
                              owl:allValuesFrom hp:AdministrativeArea
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:ownership ;
                              owl:allValuesFrom [ rdf:type owl:Class ;
                                                  owl:unionOf ( org:Organization
                                                                <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Person/Person>
                                                              )
                                                ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:hasNumberOfRooms ;
                              owl:allValuesFrom xsd:nonNegativeInteger
                            ] ;
            rdfs:comment "A Building is a structure with a roof and walls. The HPCDM Building class extends the ISO/IEC 5087-2 Building class to capture additional properties that are relevant for housing potential." .


###  http://ontology.eil.utoronto.ca/HPCDM/BuildingCondition
hp:BuildingCondition rdf:type owl:Class ;
                     rdfs:subClassOf hp:BuildingThing ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty Code:hasCode ;
                                       owl:allValuesFrom Code:Code
                                     ] ;
                     rdfs:comment "A representation of the condition of a building. May be defined with different classification systems." .


###  http://ontology.eil.utoronto.ca/HPCDM/BuildingFootprintArea
hp:BuildingFootprintArea rdf:type owl:Class ;
                         rdfs:subClassOf hp:BuildingThing ,
                                         CityUnits:Area ;
                         rdfs:comment "In general, it is defined as the area of a Building’s footprint. Differences in the definition of a building’s footprint may arise in different municipalities and applications; these may be captured with extensions to this class, as required." .


###  http://ontology.eil.utoronto.ca/HPCDM/BuildingHeight
hp:BuildingHeight rdf:type owl:Class ;
                  rdfs:subClassOf hp:BuildingThing ,
                                  CityUnits:Area ;
                  rdfs:comment "Refers to the height of a building, which can be measured in stories as well as units of measure typically associated with length. The precise definition of BuildingHeight may vary between municipalities (i.e., the definitions of the reference points for the measurement), so this class may be extended to capture these distinctions." .


###  http://ontology.eil.utoronto.ca/HPCDM/BuildingSetback
hp:BuildingSetback rdf:type owl:Class ;
                   rdfs:subClassOf hp:BuildingThing .


###  http://ontology.eil.utoronto.ca/HPCDM/BuildingThing
hp:BuildingThing rdf:type owl:Class ;
                 rdfs:subClassOf hp:HPCDMThing ;
                 rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/BuildingUnit
hp:BuildingUnit rdf:type owl:Class ;
                rdfs:subClassOf hp:BuildingThing ,
                                Building:BuildingUnit ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty hp:hasFloorArea ;
                                  owl:allValuesFrom hp:FloorArea
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty hp:occupiedBy ;
                                  owl:allValuesFrom [ rdf:type owl:Class ;
                                                      owl:unionOf ( org:Organization
                                                                    <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Person/Person>
                                                                  )
                                                    ]
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty hp:ownership ;
                                  owl:allValuesFrom [ rdf:type owl:Class ;
                                                      owl:unionOf ( org:Organization
                                                                    <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Person/Person>
                                                                  )
                                                    ]
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty Building:use ;
                                  owl:allValuesFrom Building:BuildingUse
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty hp:hasNumberOfRooms ;
                                  owl:allValuesFrom xsd:nonNegativeInteger
                                ] ;
                rdfs:comment "A BuildingUnit refers to a part of a Building that is physically separate (i.e. has its own entrance and its own identifier within the building). It extends the 5087-2:BuildingUnit class with additional properties relevant for housing potential." .


###  http://ontology.eil.utoronto.ca/HPCDM/CatchmentArea
hp:CatchmentArea rdf:type owl:Class ;
                 rdfs:subClassOf hp:ServiceAccessThing ,
                                 <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location> ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasDescription> ;
                                   owl:allValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasIdentifier> ;
                                   owl:allValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasName> ;
                                   owl:allValuesFrom xsd:string
                                 ] .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareAvailableEnrollmentSpaces
hp:ChildcareAvailableEnrollmentSpaces rdf:type owl:Class ;
                                      rdfs:subClassOf hp:ChildcareServiceAccessThing ,
                                                      hp:ChildcareServiceCapacity ,
                                                      hp:DifferenceQuantity ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass hp:ChildcareEnrollmentSpaces
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass hp:ChildcareEnrollmentSize
                                                      ] ;
                                      rdfs:comment "a DifferenceQuantity that represents the available spaces for enrollment at a childcare service." ;
                                      rdfs:label "Available enrollment spaces" .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareEnrollmentPopulation
hp:ChildcareEnrollmentPopulation rdf:type owl:Class ;
                                 rdfs:subClassOf hp:ChildcareServiceAccessThing ,
                                                 <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ;
                                 rdfs:comment "a i72:Population of persons (children) enrolled in the childcare service." .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareEnrollmentSize
hp:ChildcareEnrollmentSize rdf:type owl:Class ;
                           rdfs:subClassOf hp:ChildcareServiceAccessThing ,
                                           hp:ChildcareServiceCapacity ,
                                           <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass hp:ChildcareEnrollmentPopulation
                                           ] ;
                           rdfs:comment "ChildcareEnrollmentSize is a specialization of ChildcareServiceCapacity and i72:Quantity. It provides a count of the current population enrolled at the childcare service. It may be used as a measure of the childcare service’s capacity in use" ;
                           rdfs:label "Current enrollment" .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareEnrollmentSpacePopulation
hp:ChildcareEnrollmentSpacePopulation rdf:type owl:Class ;
                                      rdfs:subClassOf hp:ChildcareServiceAccessThing ,
                                                      <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ;
                                      rdfs:comment "a i72:Population of enrollment spaces at a childcare service." .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareEnrollmentSpaces
hp:ChildcareEnrollmentSpaces rdf:type owl:Class ;
                             rdfs:subClassOf hp:ChildcareServiceAccessThing ,
                                             hp:ChildcareServiceCapacity ,
                                             <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass hp:ChildcareEnrollmentSpacePopulation
                                             ] ;
                             rdfs:comment "a specialization of ChildcareServiceCapacity. It is an i72:Quantity that specifies a count of the current number of spaces (i.e., spots for enrollment) for the childcare service. It may be used as a measure of the childcare service’s total capacity." ;
                             rdfs:label "Total enrollment spaces" .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareService
hp:ChildcareService rdf:type owl:Class ;
                    rdfs:subClassOf hp:ChildcareServiceAccessThing ,
                                    hp:Service ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty hp:hasPlannedCapacity ;
                                      owl:allValuesFrom hp:ChildcareServiceCapacity
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty hp:providedFromSite ;
                                      owl:allValuesFrom hp:ChildcareSite
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                      owl:allValuesFrom hp:ChildcareServiceCapacity
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                      owl:allValuesFrom hp:ChildcareServiceCapacity
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                      owl:allValuesFrom hp:ChildcareServiceCapacity
                                    ] ;
                    rdfs:comment "ChildcareService refers to the professional supervision and caretaking of children. Childcare services are considered separately from school services." ;
                    rdfs:label "Childcare" ;
                    skos:altLabel "Childcare service" .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareServiceAccessThing
hp:ChildcareServiceAccessThing rdf:type owl:Class ;
                               rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareServiceCapacity
hp:ChildcareServiceCapacity rdf:type owl:Class ;
                            rdfs:subClassOf hp:ChildcareServiceAccessThing ,
                                            [ rdf:type owl:Class ;
                                              owl:unionOf ( hp:QuantityConstraint
                                                            <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                          )
                                            ] ;
                            rdfs:comment "ChildcareServiceCapacity is an i72:Quantity or QuantityConstraint that captures a measure of the capacity of a childcare service" .


###  http://ontology.eil.utoronto.ca/HPCDM/ChildcareSite
hp:ChildcareSite rdf:type owl:Class ;
                 rdfs:subClassOf hp:ChildcareServiceAccessThing ,
                                 org:Site ;
                 rdfs:comment "identifies the physical premise where the childcare service is provided." .


###  http://ontology.eil.utoronto.ca/HPCDM/CommunityCentreAvailableSpaces
hp:CommunityCentreAvailableSpaces rdf:type owl:Class ;
                                  rdfs:subClassOf hp:CommunityCentreCapacity ,
                                                  hp:CommunityCentreServiceAccessThing ,
                                                  hp:DifferenceQuantity ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                    owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_cardinality_unit>
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass hp:CommunityCentreClientSpaces
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass hp:CommunityCentreClientSize
                                                  ] ;
                                  rdfs:comment "an i72:Quantity that captures a measure of the available spaces (if any) that a centre is capable of supporting. It is defined as the difference between the CommunityCentreClientSpaces and the CommunityCentreClientSize." ;
                                  rdfs:label "Spaces available for new users" .


###  http://ontology.eil.utoronto.ca/HPCDM/CommunityCentreCapacity
hp:CommunityCentreCapacity rdf:type owl:Class ;
                           rdfs:subClassOf hp:CommunityCentreServiceAccessThing ,
                                           [ rdf:type owl:Class ;
                                             owl:unionOf ( hp:QuantityConstraint
                                                           <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                         )
                                           ] ;
                           rdfs:comment "a specialization of i72:Quantity that captures a measure of the capacity of a community centre service. Client size (number of users of the centre) and client spaces (i.e., the size of population the centre was designed to service) are two possible measures of capacity. Other approximations such as square footage to nearby population could also be captured in extensions." .


###  http://ontology.eil.utoronto.ca/HPCDM/CommunityCentreClientSize
hp:CommunityCentreClientSize rdf:type owl:Class ;
                             rdfs:subClassOf hp:CommunityCentreCapacity ,
                                             hp:CommunityCentreServiceAccessThing ,
                                             <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                               owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_cardinality_unit>
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass hp:ResidentPopulation
                                             ] ;
                             rdfs:comment "an i72:Quantity that captures a measure of the population currently serviced by the community centre (i.e., the population within its catchment area). Client sizes and the service areas by which they are determined are likely to vary based on context (e.g., urban or rural) and size of the centre. It may be used as a measure of a service’s capacity in-use." ;
                             rdfs:label "Current number of users" .


###  http://ontology.eil.utoronto.ca/HPCDM/CommunityCentreClientSpaces
hp:CommunityCentreClientSpaces rdf:type owl:Class ;
                               rdfs:subClassOf hp:CommunityCentreCapacity ,
                                               hp:CommunityCentreServiceAccessThing ,
                                               hp:QuantityConstraint ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                 owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_cardinality_unit>
                                               ] ;
                               rdfs:comment "a QuantityConstraint that captures a measure of the maximum number of residents that a centre was designed to service (i.e., overall as opposed to a single point in time). It may be used as a measure of a service’s total capacity." ;
                               rdfs:label "Total user capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/CommunityCentreService
hp:CommunityCentreService rdf:type owl:Class ;
                          rdfs:subClassOf hp:CommunityCentreServiceAccessThing ,
                                          hp:LowIncomeSupportService ,
                                          hp:Service ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty hp:hasPlannedCapacity ;
                                            owl:allValuesFrom hp:CommunityCentreCapacity
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty hp:providedFromSite ;
                                            owl:allValuesFrom hp:CommunityCentreSite
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                            owl:allValuesFrom hp:CommunityCentreCapacity
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                            owl:allValuesFrom hp:CommunityCentreCapacity
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                            owl:allValuesFrom hp:CommunityCentreCapacity
                                          ] ;
                          rdfs:comment "represents the service provided by community centres such as access to facilities and various programming. Different community centres may provide different types of these services, but they can all be classified as a general CommunityCentreService (or part of such a general service). CommunityCentreService is a subclass of LowIncomeSupportService." ;
                          rdfs:label "Community centre" ;
                          skos:altLabel "Community centre service" .


###  http://ontology.eil.utoronto.ca/HPCDM/CommunityCentreServiceAccessThing
hp:CommunityCentreServiceAccessThing rdf:type owl:Class ;
                                     rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/CommunityCentreSite
hp:CommunityCentreSite rdf:type owl:Class ;
                       rdfs:subClassOf hp:CommunityCentreServiceAccessThing ,
                                       org:Site ;
                       rdfs:comment "a specialization of org:Site that represents the community centre (the facility) where the service is provided." .


###  http://ontology.eil.utoronto.ca/HPCDM/ConstraintSpecification
hp:ConstraintSpecification rdf:type owl:Class ;
                           rdfs:subClassOf hp:QuantityConstraintThing ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty om-1:unit_of_measure ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass om-1:Unit_of_measure
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty om-1:numerical_value ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:string
                                           ] ;
                           rdfs:comment "A ConstraintSpecification represents an actual value of the limitation set by the QuantityConstraint. Like the 21972:Measure class, this is formalized with the 21972:numerical_value and 21972:unit_of_measure properties." .


###  http://ontology.eil.utoronto.ca/HPCDM/DifferenceQuantity
hp:DifferenceQuantity rdf:type owl:Class ;
                      rdfs:subClassOf hp:QuantityThing ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onClass om-1:Quantity
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onClass om-1:Quantity
                                      ] ;
                      rdfs:comment "A type of i72:Quantity that is defined as the difference between two i72:Quantity objects" .


###  http://ontology.eil.utoronto.ca/HPCDM/DwellingUnit
hp:DwellingUnit rdf:type owl:Class ;
                rdfs:subClassOf hp:BuildingThing ,
                                [ rdf:type owl:Class ;
                                  owl:unionOf ( hp:Building
                                                hp:BuildingUnit
                                              )
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty Building:use ;
                                  owl:hasValue hp:residential_occupancy
                                ] ;
                rdfs:comment "A specialization of a Building or Building Unit that is intended to provide a living accommodation for a household." .


###  http://ontology.eil.utoronto.ca/HPCDM/ElectricLoad
hp:ElectricLoad rdf:type owl:Class ;
                rdfs:subClassOf hp:ElectricServiceCapacity ,
                                om-1:Quantity ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty hp:forLocation ;
                                  owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                  owl:hasValue hp:kilovolt_ampere
                                ] ;
                rdfs:comment "The electrical load capacity specifies the (peak) amount of electricity delivered to an area. It is a measure of the capacity in use of a service." ;
                rdfs:label "Peak load capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/ElectricService
hp:ElectricService rdf:type owl:Class ;
                   rdfs:subClassOf hp:ElectricityServiceAccessThing ,
                                   hp:Utility ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty hp:hasPlannedCapacity ;
                                     owl:allValuesFrom hp:ElectricServiceCapacity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                     owl:allValuesFrom hp:ElectricServiceCapacity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                     owl:allValuesFrom hp:ElectricServiceCapacity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                     owl:allValuesFrom hp:ElectricServiceCapacity
                                   ] ;
                   rdfs:comment "represents the service that delivers electricity to customers (residential and commercial) from some power generation service. It is defined as a Utility." .


###  http://ontology.eil.utoronto.ca/HPCDM/ElectricServiceCapacity
hp:ElectricServiceCapacity rdf:type owl:Class ;
                           rdfs:subClassOf hp:ElectricityServiceAccessThing ,
                                           [ rdf:type owl:Class ;
                                             owl:unionOf ( hp:QuantityConstraint
                                                           om-1:Quantity
                                                         )
                                           ] ;
                           rdfs:comment "represents a measure of the capacity of the power service (total, in use, or available)." .


###  http://ontology.eil.utoronto.ca/HPCDM/ElectricalLoadCapacity
hp:ElectricalLoadCapacity rdf:type owl:Class ;
                          rdfs:subClassOf hp:ElectricServiceCapacity ,
                                          om-1:Quantity ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty hp:forLocation ;
                                            owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                            owl:hasValue hp:kilovolt_ampere
                                          ] ;
                          rdfs:comment "The electrical load capacity specifies the amount of electricity that can be delivered to an area (i.e., based on the local grid infrastructure). It is one possible measure of the capacity of an electrical service." ;
                          rdfs:label "Total load capacity" .


###  http://ontology.eil.utoronto.ca/HPCDM/ElectricityServiceAccessThing
hp:ElectricityServiceAccessThing rdf:type owl:Class ;
                                 rdfs:subClassOf hp:HPCDMThing ;
                                 rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/ElementarySchoolService
hp:ElementarySchoolService rdf:type owl:Class ;
                           rdfs:subClassOf hp:SchoolService .


###  http://ontology.eil.utoronto.ca/HPCDM/EmergencyBedCount
hp:EmergencyBedCount rdf:type owl:Class ;
                     rdfs:subClassOf hp:MedicalServiceAccessThing ,
                                     <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                       owl:allValuesFrom hp:HospitalEmergencyBedPopulation
                                     ] ;
                     rdfs:comment "a i72:Cardinality of the number of EmergencyBeds in the location of interest." .


###  http://ontology.eil.utoronto.ca/HPCDM/EmergencyBedPopulationRatio
hp:EmergencyBedPopulationRatio rdf:type owl:Class ;
                               rdfs:subClassOf hp:EmergencyCareServiceCapacity ,
                                               hp:MedicalServiceAccessThing ,
                                               hp:RatioQuantity ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty hp:forLocation ;
                                                 owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                 owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass hp:ResidentPopulationSize
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass hp:EmergencyBedCount
                                               ] ;
                               rdfs:comment "a type of EmergencyCareServiceCapacity that is the ratio of the number of emergency care beds to the population of the catchment area." ;
                               rdfs:label "Number of beds per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/EmergencyCareServiceCapacity
hp:EmergencyCareServiceCapacity rdf:type owl:Class ;
                                rdfs:subClassOf hp:MedicalServiceAccessThing ,
                                                [ rdf:type owl:Class ;
                                                  owl:unionOf ( hp:QuantityConstraint
                                                                <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                              )
                                                ] ;
                                rdfs:comment "a specialization of i72:Quantity that captures a measure of the capacity of an emergency/urgent care service." .


###  http://ontology.eil.utoronto.ca/HPCDM/EmergencyHospitalBed
hp:EmergencyHospitalBed rdf:type owl:Class ;
                        rdfs:subClassOf gcih:HospitalBed ,
                                        hp:MedicalServiceAccessThing ;
                        rdfs:comment "a subclass of gcih:HospitalBeds that captures only the beds used for temporary, acute care when patients are admitted to the emergency room." .


###  http://ontology.eil.utoronto.ca/HPCDM/EmergencyServicesCapacity
hp:EmergencyServicesCapacity rdf:type owl:Class ;
                             rdfs:subClassOf hp:FireEmergencyServiceAccessThing ,
                                             [ rdf:type owl:Class ;
                                               owl:unionOf ( hp:QuantityConstraint
                                                             om-1:Quantity
                                                           )
                                             ] ;
                             rdfs:comment "a type of i72:Quantity or QuantityConstraint that represents the capacity of an emergency service. Various measures of capacity may be defined as appropriate and available." .


###  http://ontology.eil.utoronto.ca/HPCDM/EnvironmentalHazard
hp:EnvironmentalHazard rdf:type owl:Class ;
                       rdfs:subClassOf hp:EnvironmentalRiskThing ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty hp:hasImpact ;
                                         owl:someValuesFrom hp:HazardImpact
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty hp:hasRiskFactor ;
                                         owl:allValuesFrom hp:HazardRiskFactor
                                       ] ;
                       rdfs:comment "represents the actual hazard event that has the potential to cause damage and harm." .


###  http://ontology.eil.utoronto.ca/HPCDM/EnvironmentalRiskThing
hp:EnvironmentalRiskThing rdf:type owl:Class ;
                          rdfs:subClassOf hp:HPCDMThing ;
                          rdfs:comment "This pattern is informed by current research that examines the taxonomies of climate hazards (a specific class of environmental hazard), impacts, and risk factors [35]. It may be considered a kind of “stub” pattern; it serves as a high-level outline of some of the key considerations, further exploration is not required for the scope of the HPCDM, but should be pursued in future work." .


###  http://ontology.eil.utoronto.ca/HPCDM/FireEmergencyService
hp:FireEmergencyService rdf:type owl:Class ;
                        rdfs:subClassOf hp:FireEmergencyServiceAccessThing ,
                                        hp:Service ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/CityService/hasCatchmentArea> ;
                                          owl:someValuesFrom hp:CatchmentArea
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty hp:hasPlannedCapacity ;
                                          owl:allValuesFrom hp:EmergencyServicesCapacity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                          owl:allValuesFrom hp:EmergencyServicesCapacity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                          owl:allValuesFrom hp:EmergencyServicesCapacity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                          owl:allValuesFrom hp:EmergencyServicesCapacity
                                        ] ;
                        rdfs:comment "a type of Service that involves the immediate provision assistance (via skilled personnel and sometimes specialized equipment) in response to situations that pose a serious risk to health, property, or the environment." ;
                        rdfs:label "Fire emergency" ;
                        skos:altLabel "Fire emergency service" .


###  http://ontology.eil.utoronto.ca/HPCDM/FireEmergencyServiceAccessThing
hp:FireEmergencyServiceAccessThing rdf:type owl:Class ;
                                   rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/FirefightersPerPopulation
hp:FirefightersPerPopulation rdf:type owl:Class ;
                             rdfs:subClassOf hp:EmergencyServicesCapacity ,
                                             om-1:Quantity ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty hp:forLocation ;
                                               owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                               owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass hp:ResidentPopulationSize
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass hp:FullTimeFirefighterCount
                                             ] ;
                             rdfs:comment "a type of EmergencyServicesCapacity, it is one means of specifying the capacity in use. It is the actual measure of firefighters per population, defined analogously to the indicator specified in the GCIO Fire and Emergency Response Ontology: a ratio indicator with a numerator of the number of fulltime firefighter, and a denominator of the population (in this case, of any area, not just the entire city). It may corresponds to the capacity in use." ;
                             rdfs:label "Number of firefighters per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/Flood
hp:Flood rdf:type owl:Class ;
         rdfs:subClassOf hp:EnvironmentalHazard ,
                         hp:EnvironmentalRiskThing ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty hp:hasRiskFactor ;
                           owl:someValuesFrom hp:Floodplain
                         ] ;
         rdfs:comment "a type of EnvironmentalHazard. Note that this class is included for demonstration purposes; this pattern is not intended to be exhaustive in its coverage of hazard types." .


###  http://ontology.eil.utoronto.ca/HPCDM/Floodplain
hp:Floodplain rdf:type owl:Class ;
              rdfs:subClassOf hp:EnvironmentalRiskThing ,
                              hp:HazardRiskFactor ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:forWatershed ;
                                owl:allValuesFrom hp:Watershed
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:minDistanceToWater ;
                                owl:allValuesFrom CityUnits:Length
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/hasLocation> ;
                                owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty [ owl:inverseOf <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/partOf>
                                               ] ;
                                owl:allValuesFrom hp:FloodplainSegment
                              ] ;
              rdfs:comment "a type of HazardRiskFactor (included for demonstration purposes as this pattern is not intended to be exhaustive) that impacts influences the severity of impact of a Flood." .


###  http://ontology.eil.utoronto.ca/HPCDM/FloodplainSegment
hp:FloodplainSegment rdf:type owl:Class ;
                     rdfs:subClassOf hp:EnvironmentalRiskThing ,
                                     hp:HazardRiskFactor ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty hp:forWatershed ;
                                       owl:allValuesFrom hp:Watershed
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty hp:minDistanceToWater ;
                                       owl:allValuesFrom CityUnits:Length
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/hasLocation> ;
                                       owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty [ owl:inverseOf <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/partOf>
                                                      ] ;
                                       owl:allValuesFrom hp:FloodplainSegment
                                     ] ;
                     rdfs:comment "a type of HazardRiskFactor that describes a (geographical) part of a floodplai. Note that this class is included for demonstration purposes; this pattern is not intended to be exhaustive in its coverage of hazard types." .


###  http://ontology.eil.utoronto.ca/HPCDM/FloorArea
hp:FloorArea rdf:type owl:Class ;
             rdfs:subClassOf hp:BuildingThing ,
                             CityUnits:Area ;
             rdfs:comment "Refers to the total floor area of the subject. Differences in the definition of total floor area (e.g., what floors and parts are included) may vary, and this class may be extended to capture these distinctions as required." .


###  http://ontology.eil.utoronto.ca/HPCDM/FloorSpaceIndex
hp:FloorSpaceIndex rdf:type owl:Class ;
                   rdfs:subClassOf <http://ontology.eil.utoronto.ca/GCI/Foundation/GCI-Foundation-v2.owl#GCIRatioQuantity> ,
                                   hp:AdministrativeAreaThing ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                     owl:allValuesFrom CityUnits:Area
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                     owl:allValuesFrom <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Sum>
                                   ] ;
                   rdfs:comment "Floor Space Index (FSI) is a subclass of 21972:RatioQuantity. In general, it is defined as the numerator is the total built floor area and the denominator is the area of the land (AdministrativeArea) it is a property of. Distinctions between how the FSI is calculated may be defined with extensions to this class, as required." .


###  http://ontology.eil.utoronto.ca/HPCDM/FoodServiceAccessThing
hp:FoodServiceAccessThing rdf:type owl:Class ;
                          rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/Frontage
hp:Frontage rdf:type owl:Class ;
            rdfs:subClassOf hp:AdministrativeAreaThing ,
                            CityUnits:Length ;
            rdfs:comment "Frontage is a kind of 5087-1:Length quantity. In general, it refers to the street facing length of an area of land (AdministrativeArea). The way that Frontage is measured can vary, therefore this class may be extended to capture these distinctions (e.g., TorontoLotFrontage, HalifaxLotFrontage)." .


###  http://ontology.eil.utoronto.ca/HPCDM/FullTimeFirefighterCount
hp:FullTimeFirefighterCount rdf:type owl:Class ;
                            rdfs:subClassOf hp:FireEmergencyServiceAccessThing ,
                                            <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass <http://ontology.eil.utoronto.ca/GCI/ISO37120/FireEmergency.owl#10.1_FullTime_FireFighter_OperationalStaff>
                                            ] ;
                            rdfs:comment "is a cardinality class that represents the size of a population of firefighterters, defined by the class gcife:10.1_FullTimeFirefighter_OpationalStaff_population" .


###  http://ontology.eil.utoronto.ca/HPCDM/HPCDMThing
hp:HPCDMThing rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/HPCDM/HazardImpact
hp:HazardImpact rdf:type owl:Class ;
                rdfs:subClassOf hp:EnvironmentalRiskThing ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty [ owl:inverseOf hp:hasImpact
                                                 ] ;
                                  owl:someValuesFrom hp:EnvironmentalHazard
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty [ owl:inverseOf hp:influencesImpact
                                                 ] ;
                                  owl:allValuesFrom hp:HazardRiskFactor
                                ] ;
                rdfs:comment "represents the impact of a hazard event." .


###  http://ontology.eil.utoronto.ca/HPCDM/HazardRiskFactor
hp:HazardRiskFactor rdf:type owl:Class ;
                    rdfs:subClassOf hp:EnvironmentalRiskThing ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty hp:influencesImpact ;
                                      owl:allValuesFrom hp:HazardImpact
                                    ] ;
                    rdfs:comment "a risk factor is some characteristic that is known to influence the likelihood and/or severity of a climate hazard event." .


###  http://ontology.eil.utoronto.ca/HPCDM/HospitalBedCount
hp:HospitalBedCount rdf:type owl:Class ;
                    rdfs:subClassOf hp:MedicalServiceAccessThing ,
                                    <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                      owl:allValuesFrom hp:HospitalBedPopulation
                                    ] ;
                    rdfs:comment "is a i72:Cardinality that represents a count of the number of gcih:HospitalBeds in the location of interest." .


###  http://ontology.eil.utoronto.ca/HPCDM/HospitalBedPopulation
hp:HospitalBedPopulation rdf:type owl:Class ;
                         rdfs:subClassOf hp:MedicalServiceAccessThing ,
                                         <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#defined_by> ;
                                           owl:allValuesFrom gcih:HospitalBed
                                         ] ;
                         rdfs:comment "is an i72:Population quantity that captures the population of hospital beds in a particular area (i.e., at a particular hospital). Its members are defined_by the gcih:HospitalBed class." .


###  http://ontology.eil.utoronto.ca/HPCDM/HospitalBedPopulationRatio
hp:HospitalBedPopulationRatio rdf:type owl:Class ;
                              rdfs:subClassOf hp:HospitalServiceCapacity ,
                                              hp:MedicalServiceAccessThing ,
                                              hp:RatioQuantity ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty hp:forLocation ;
                                                owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass hp:ResidentPopulationSize
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass hp:HospitalBedCount
                                              ] ;
                              rdfs:comment "a type of HospitalServiceCapacity that is defined as the ratio of the number of hospital beds to the population of the catchment area." ;
                              rdfs:label "Beds per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/HospitalEmergencyBedPopulation
hp:HospitalEmergencyBedPopulation rdf:type owl:Class ;
                                  rdfs:subClassOf hp:MedicalServiceAccessThing ,
                                                  <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#defined_by> ;
                                                    owl:allValuesFrom hp:EmergencyHospitalBed
                                                  ] ;
                                  rdfs:comment "is an i72:Population quantity that captures the population of hospital beds for emergency care in a particular area (i.e., at a particular hospital). Its members are defined_by the EmergencyHospitalBed class." .


###  http://ontology.eil.utoronto.ca/HPCDM/HospitalEmergencyService
hp:HospitalEmergencyService rdf:type owl:Class ;
                            rdfs:subClassOf cdt:HospitalEmergencyService ,
                                            hp:MedicalServiceAccessThing ,
                                            hp:Service ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty [ owl:inverseOf hp:hasSubService
                                                             ] ;
                                              owl:someValuesFrom hp:HospitalService
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty hp:hasPlannedCapacity ;
                                              owl:allValuesFrom hp:EmergencyCareServiceCapacity
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                              owl:allValuesFrom hp:EmergencyCareServiceCapacity
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                              owl:allValuesFrom hp:EmergencyCareServiceCapacity
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                              owl:allValuesFrom hp:EmergencyCareServiceCapacity
                                            ] ;
                            rdfs:comment "a type of Service that is offered by some hospitals (often referred to as “Emergency” or “Urgent Care”). It is distinguished from the larger HospitalService as its individual capacity is often of interest as it represents a critical capacity issue, with longer wait times having serious and immediate consequences." ;
                            rdfs:label "Hospital emergency" ;
                            skos:altLabel "Hospital emergency service" .


###  http://ontology.eil.utoronto.ca/HPCDM/HospitalService
hp:HospitalService rdf:type owl:Class ;
                   rdfs:subClassOf hp:MedicalServiceAccessThing ,
                                   hp:Service ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty hp:hasPlannedCapacity ;
                                     owl:allValuesFrom hp:HospitalServiceCapacity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty hp:providedFromSite ;
                                     owl:allValuesFrom hp:HospitalSite
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                     owl:allValuesFrom hp:HospitalServiceCapacity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                     owl:allValuesFrom hp:HospitalServiceCapacity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                     owl:allValuesFrom hp:HospitalServiceCapacity
                                   ] ;
                   rdfs:comment "represents the service provided by hospitals, such as access to specialized treatments and emergency healthcare." ;
                   rdfs:label "Hospital" ;
                   skos:altLabel "Hospital service" .


###  http://ontology.eil.utoronto.ca/HPCDM/HospitalServiceCapacity
hp:HospitalServiceCapacity rdf:type owl:Class ;
                           rdfs:subClassOf hp:MedicalServiceAccessThing ,
                                           [ rdf:type owl:Class ;
                                             owl:unionOf ( hp:QuantityConstraint
                                                           <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                         )
                                           ] ;
                           rdfs:comment "a specialization of i72:Quantity that captures a measure of the capacity of a hospital service." .


###  http://ontology.eil.utoronto.ca/HPCDM/HospitalSite
hp:HospitalSite rdf:type owl:Class ;
                rdfs:subClassOf hp:MedicalServiceAccessThing ,
                                org:Site .


###  http://ontology.eil.utoronto.ca/HPCDM/InformationArtifact
hp:InformationArtifact rdf:type owl:Class ;
                       rdfs:subClassOf hp:InformationArtifactThing ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty prov:wasAttributedTo ;
                                         owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Agent/Agent>
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasDescription> ;
                                         owl:allValuesFrom xsd:string
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasIdentifier> ;
                                         owl:allValuesFrom xsd:string
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasName> ;
                                         owl:allValuesFrom xsd:string
                                       ] .


###  http://ontology.eil.utoronto.ca/HPCDM/InformationArtifactThing
hp:InformationArtifactThing rdf:type owl:Class ;
                            rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/LandDevelopmentClassification
hp:LandDevelopmentClassification rdf:type owl:Class ;
                                 rdfs:subClassOf hp:AdministrativeAreaThing ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty Code:hasCode ;
                                                   owl:allValuesFrom Code:Code
                                                 ] .


###  http://ontology.eil.utoronto.ca/HPCDM/LandUse
hp:LandUse rdf:type owl:Class ;
           rdfs:subClassOf hp:AdministrativeAreaThing ,
                           oz:LandUse ,
                           <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/LandUse/LandUseClassification> ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:includesLandUse ;
                             owl:allValuesFrom hp:LandUse
                           ] ;
           rdfs:comment "refers to the general classification of the land use (permitted, planned or current) occurring on an area of land. It is typically defined at a high level (e.g. residential, commercial), though the granularity of land use types is not restricted by the HPCDM. The Code class is used to support the use and/or alignment of any classification systems. Land Use is a specialization of 5087-1:LandUse and OZ:LandUse that integrates the two models. In the OZ ontology, the definition of Land Use is intended (though not restricted) to focus on more granular land use types/activities, however the HPCDM Land Use includes both generalized classifications (such as residential) and more specific land use “types” (e.g. single-unit dwelling, library). The connection between generalized and more specific types of land use is formalized with the includesLandUse property." .


###  http://ontology.eil.utoronto.ca/HPCDM/LibraryAreaPopulationRatio
hp:LibraryAreaPopulationRatio rdf:type owl:Class ;
                              rdfs:subClassOf hp:LibraryServiceAccessThing ,
                                              hp:LibraryServiceCapacity ,
                                              hp:RatioQuantity ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                owl:hasValue hp:square_metre_per_person
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass hp:ResidentPopulationSize
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass hp:LibraryAreaSum
                                              ] ;
                              rdfs:comment "a type of LibraryServiceCapacity that is the ratio of the total library floor area to the population it is intended to service ( in its catchment area). It is an i72:Quantity." ;
                              rdfs:label "Total library floor area per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/LibraryAreaSum
hp:LibraryAreaSum rdf:type owl:Class ;
                  rdfs:subClassOf hp:LibraryServiceAccessThing ,
                                  <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Sum> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#parameter_of_var> ;
                                    owl:allValuesFrom [ owl:intersectionOf ( <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Variable>
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#has_Name> ;
                                                                               owl:hasValue "http://ontology.eil.utoronto.ca/HPCDM/hasFloorArea"
                                                                             ]
                                                                           ) ;
                                                        rdf:type owl:Class
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#sum_of> ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass hp:LibraryPopulation
                                  ] ;
                  rdfs:comment "an i72:Sum that represents the total library floor area (from all libraries) in a particular area." .


###  http://ontology.eil.utoronto.ca/HPCDM/LibraryPopulation
hp:LibraryPopulation rdf:type owl:Class ;
                     rdfs:subClassOf hp:LibraryServiceAccessThing ,
                                     <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#defined_by> ;
                                       owl:allValuesFrom cdt:LibrarySite
                                     ] ;
                     rdfs:comment "an i72:Population that represents the libraries within a particular area." .


###  http://ontology.eil.utoronto.ca/HPCDM/LibraryService
hp:LibraryService rdf:type owl:Class ;
                  rdfs:subClassOf cdt:LibraryService ,
                                  hp:LibraryServiceAccessThing ,
                                  hp:LowIncomeSupportService ,
                                  hp:Service ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty hp:hasPlannedCapacity ;
                                    owl:allValuesFrom hp:LibraryServiceCapacity
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty hp:providedFromSite ;
                                    owl:allValuesFrom cdt:LibrarySite
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                    owl:allValuesFrom hp:LibraryServiceCapacity
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                    owl:allValuesFrom hp:LibraryServiceCapacity
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                    owl:allValuesFrom hp:LibraryServiceCapacity
                                  ] ;
                  rdfs:comment "represents the service provided by libraries such as access to books and programming. It is a subclass of cdt:LibraryService and LowIncomeSupportService." ;
                  rdfs:label "Library" ;
                  skos:altLabel "Library service" .


###  http://ontology.eil.utoronto.ca/HPCDM/LibraryServiceAccessThing
hp:LibraryServiceAccessThing rdf:type owl:Class ;
                             rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/LibraryServiceCapacity
hp:LibraryServiceCapacity rdf:type owl:Class ;
                          rdfs:subClassOf hp:LibraryServiceAccessThing ,
                                          [ rdf:type owl:Class ;
                                            owl:unionOf ( hp:QuantityConstraint
                                                          <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                        )
                                          ] ;
                          rdfs:comment "a type of i72:Quantity or QuantityConstraint that captures a measure of the capacity of a library service. ClientSize and ClientSpaces are two quantities that could be used to describe a library service’s capacity. Alternative capacity measures that could be specified in an extension to the HPCDM include branch visits or items checked out." .


###  http://ontology.eil.utoronto.ca/HPCDM/LongTermCareBedPopulation
hp:LongTermCareBedPopulation rdf:type owl:Class ;
                             rdfs:subClassOf hp:SeniorServiceAccessThing ,
                                             <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ;
                             rdfs:comment "is an i72:Population quantity that captures the population of long term care beds in a particular area (i.e., at a particular facility)." .


###  http://ontology.eil.utoronto.ca/HPCDM/LongTermCareFacility
hp:LongTermCareFacility rdf:type owl:Class ;
                        rdfs:subClassOf hp:SeniorServiceAccessThing ,
                                        org:Site .


###  http://ontology.eil.utoronto.ca/HPCDM/LongTermCareResidenceService
hp:LongTermCareResidenceService rdf:type owl:Class ;
                                rdfs:subClassOf hp:LongTermCareService ,
                                                hp:SeniorServiceAccessThing ;
                                rdfs:comment "a type of long-term care service that includes residence (i.e., in an assisted living or nursing home facility). Note that other types of services might be identified in extensions to this model, such as home care services." .


###  http://ontology.eil.utoronto.ca/HPCDM/LongTermCareResidentPopulation
hp:LongTermCareResidentPopulation rdf:type owl:Class ;
                                  rdfs:subClassOf hp:SeniorServiceAccessThing ,
                                                  <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ;
                                  rdfs:comment "is an i72:Population quantity that captures the population of long term care residents in a particular area (i.e., at a particular facility)." .


###  http://ontology.eil.utoronto.ca/HPCDM/LongTermCareService
hp:LongTermCareService rdf:type owl:Class ;
                       rdfs:subClassOf hp:SeniorServiceAccessThing ,
                                       hp:Service ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty hp:hasPlannedCapacity ;
                                         owl:allValuesFrom hp:LongTermCareServiceCapacity
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty hp:providedFromSite ;
                                         owl:allValuesFrom hp:LongTermCareFacility
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                         owl:allValuesFrom hp:LongTermCareServiceCapacity
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                         owl:allValuesFrom hp:LongTermCareServiceCapacity
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                         owl:allValuesFrom hp:LongTermCareServiceCapacity
                                       ] ;
                       rdfs:comment "represents the services provided for seniors both through care facilities, or by support workers (in home care). Long-term care services focus on medical and physical needs of older adults but may also include support for emotional/social needs." ;
                       rdfs:label "Long-term care" ;
                       skos:altLabel "Long-term care service" .


###  http://ontology.eil.utoronto.ca/HPCDM/LongTermCareServiceCapacity
hp:LongTermCareServiceCapacity rdf:type owl:Class ;
                               rdfs:subClassOf hp:SeniorServiceAccessThing ,
                                               [ rdf:type owl:Class ;
                                                 owl:unionOf ( hp:QuantityConstraint
                                                               <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                             )
                                               ] ;
                               rdfs:comment "represents the capacity (total, in-use, available or planned) of a long-term care service." .


###  http://ontology.eil.utoronto.ca/HPCDM/Lot
hp:Lot rdf:type owl:Class ;
       rdfs:subClassOf hp:AdministrativeArea ,
                       oz:Plot ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty hp:allowsUse ;
                         owl:allValuesFrom hp:LandUse
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty hp:definedInPlan ;
                         owl:allValuesFrom hp:Plan
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty hp:doesNotAllowUse ;
                         owl:allValuesFrom hp:LandUse
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty hp:mayAllowUse ;
                         owl:allValuesFrom hp:LandUse
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasIdentifier> ;
                         owl:someValuesFrom xsd:string
                       ] ;
       rdfs:comment "A specialization of oz:Plot that integrates the OntoZoning definition of a Plot with the more generic 5087-2:LandArea class employed in this model. A Lot is a division of land that is created to capture land governance policies (i.e., around zoning and development). It is distinct (disjoint) from, though closely related to a Parcel. In a typical development workflow, a Parcel will be created based on a defined Lot." .


###  http://ontology.eil.utoronto.ca/HPCDM/LowIncomeSupportService
hp:LowIncomeSupportService rdf:type owl:Class ;
                           rdfs:subClassOf hp:Service ;
                           rdfs:comment "Low income support services represent a category of services, rather than a single type of service. Examples of low-income support services could include food banks, job training centres, but also resources that serve the general public such as libraries and community centres. Other services may be identified as LowIncomeSupportServices as the model is extended." ;
                           rdfs:label "Low-income support" ;
                           skos:altLabel "Low-income support service" .


###  http://ontology.eil.utoronto.ca/HPCDM/MaxVehicleThroughputRate
hp:MaxVehicleThroughputRate rdf:type owl:Class ;
                            rdfs:subClassOf hp:RatioQuantity ,
                                            hp:TransportationCapacity ,
                                            hp:TransportationServiceAccessThing ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty hp:forLocation ;
                                              owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass CityUnits:Duration
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality>
                                            ] ;
                            rdfs:comment "a kind of TransportationCapacity. It is a Ratio Quantity that represents the maximum potential VehicleThroughput for a TransportationNetworkService." ;
                            rdfs:label "Maximum vehicle throughput rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/MaxWasteProcessingRate
hp:MaxWasteProcessingRate rdf:type owl:Class ;
                          rdfs:subClassOf hp:RatioQuantity ,
                                          hp:SolidWasteServiceCapacity ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty hp:forLocation ;
                                            owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass CityUnits:Duration
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass CityUnits:Mass
                                          ] ;
                          rdfs:comment "a type of SolidWasteServiceCapacity. It is a i72:Quantity that specifies the maximum rate at which waste can be processed by the service (often, in tonnes per year)." ;
                          rdfs:label "Maximum waste processing rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/MaxWaterDistributionRate
hp:MaxWaterDistributionRate rdf:type owl:Class ;
                            rdfs:subClassOf hp:RatioQuantity ,
                                            hp:WaterDistributionCapacity ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty hp:forLocation ;
                                              owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass CityUnits:Duration
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass CityUnits:Volume
                                            ] ;
                            rdfs:comment "a type of WaterDistributionCapacity. It is a i72:Quantity that represents the maximum, total volume of water that can be distributed by the system over some time period. It is a possible measure of the total capacity of a water service." ;
                            rdfs:label "Maximum distribution rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/MaxWaterProcessingRate
hp:MaxWaterProcessingRate rdf:type owl:Class ;
                          rdfs:subClassOf hp:RatioQuantity ,
                                          hp:WastewaterServiceCapacity ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty hp:forLocation ;
                                            owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass CityUnits:Duration
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass CityUnits:Volume
                                          ] ;
                          rdfs:comment "a type of WastewaterServiceCapacity. It is a QuantityConstraint that defines the maximum volume of water (per time) that can be processed over some time period." ;
                          rdfs:label "Maximum processing rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/Maximum
hp:Maximum rdf:type owl:Class ;
           rdfs:subClassOf hp:QuantityConstraintThing ,
                           <http://ontology.eil.utoronto.ca/govstat.owl#Parameter> ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:maximumOf ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass <http://ontology.eil.utoronto.ca/govstat.owl#Population>
                           ] ;
           rdfs:comment "A specialization of the 21972:Parameter class, Maximum represents the maximum of some Variable of a 21972:Population." .


###  http://ontology.eil.utoronto.ca/HPCDM/MedicalServiceAccessThing
hp:MedicalServiceAccessThing rdf:type owl:Class ;
                             rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/MinEmergencyBedPopulationRatio
hp:MinEmergencyBedPopulationRatio rdf:type owl:Class ;
                                  rdfs:subClassOf hp:EmergencyCareServiceCapacity ,
                                                  hp:MedicalServiceAccessThing ,
                                                  hp:QuantityConstraint ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                    owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                                  ] ;
                                  rdfs:comment "a type of QuantityConstraint that specifies the minimum acceptable ratio of emergency care beds per capita. It is a constraint on the EmergencyBedPopulationRatio." ;
                                  rdfs:label "Minimum acceptable number of beds per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/MinFirefightersPerPopulation
hp:MinFirefightersPerPopulation rdf:type owl:Class ;
                                rdfs:subClassOf hp:EmergencyServicesCapacity ,
                                                hp:QuantityConstraint ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                  owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                                ] ;
                                rdfs:comment "One way of defining the capacity of fire and emergency services is in terms of a limit on the ratio of firefighters to population. As an example, it may be recommended that there be a ratio of 1 firefighter per 1000 residents. This ratio would be defined as the capacity of the service. It is a subclass of QuantityConstraint (as it is not an actual quantity of the service, but a limit imposed by some external source). It does not have a defined numerator and denominator, as it is a constraint on the ratio, not a ratio itself." ;
                                rdfs:label "Minimum acceptable number of firefighters per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/MinHospitalBedPopulationRatio
hp:MinHospitalBedPopulationRatio rdf:type owl:Class ;
                                 rdfs:subClassOf hp:HospitalServiceCapacity ,
                                                 hp:MedicalServiceAccessThing ,
                                                 hp:QuantityConstraint ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                   owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                                 ] ;
                                 rdfs:comment "a type of QuantityConstraint that specifies the minimum acceptable ratio of hospital beds per capita." ;
                                 rdfs:label "Minimum acceptable beds per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/MinLibraryAreaPopulationRatio
hp:MinLibraryAreaPopulationRatio rdf:type owl:Class ;
                                 rdfs:subClassOf hp:LibraryServiceAccessThing ,
                                                 hp:LibraryServiceCapacity ,
                                                 hp:QuantityConstraint ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                   owl:hasValue hp:square_metre_per_person
                                                 ] ;
                                 rdfs:comment "a type of QuantityConstraint that specifies the minimum acceptable ratio of library area to number of residents (i.e., library area per capita) that can serve as a kind of measure for the capacity of an area. In other words, any value below that and the area will not be able to provide satisfactory access to library services." ;
                                 rdfs:label "Minimum acceptable library floor area per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/MinPassengerThroughputRate
hp:MinPassengerThroughputRate rdf:type owl:Class ;
                              rdfs:subClassOf hp:QuantityConstraint ,
                                              hp:TransitAccessThing ,
                                              hp:TransitCapacity ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty hp:forLocation ;
                                                owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                              ] ;
                              rdfs:comment "A QuantityConstraint that indicates the minimum acceptable rate of passengers moved by the service per unit of time." ;
                              rdfs:label "Minimum acceptable passenger throughput rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/MinRecreationAreaPopulationRatio
hp:MinRecreationAreaPopulationRatio rdf:type owl:Class ;
                                    rdfs:subClassOf hp:ParkServiceAccessThing ,
                                                    hp:ParkServiceCapacity ,
                                                    hp:QuantityConstraint ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                      owl:hasValue hp:square_metre_per_person
                                                    ] ;
                                    rdfs:comment "a Quantity Constraint that represents the minimum acceptable ratio of recreation area to resident population in a particular area." ;
                                    rdfs:label "Minimum acceptable park area per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/MinSupermarketsPopulationRatio
hp:MinSupermarketsPopulationRatio rdf:type owl:Class ;
                                  rdfs:subClassOf hp:FoodServiceAccessThing ,
                                                  hp:QuantityConstraint ,
                                                  hp:SupermarketServiceCapacity ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                    owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                                  ] ;
                                  rdfs:comment "a QuantityConstraint on a particular supermarket population ratio. It represents some recommended minimum value for a ratio of the number of supermarkets to resident population (i.e., supermarkets per capita) that can serve as a kind of measure for the capacity of an area. In other words, any value below that and the area will not be able to provide satisfactory access to supermarket (grocery) services." ;
                                  rdfs:label "Minimum acceptable number of supermarkets per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/Minimum
hp:Minimum rdf:type owl:Class ;
           rdfs:subClassOf hp:QuantityConstraintThing ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:minimumOf ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass <http://ontology.eil.utoronto.ca/govstat.owl#Population>
                           ] ;
           rdfs:comment "A specialization of the 21972:Parameter class, Minimum represents the minimum of some Variable of a 21972:Population." .


###  http://ontology.eil.utoronto.ca/HPCDM/NumberOfLongTermCareBeds
hp:NumberOfLongTermCareBeds rdf:type owl:Class ;
                            rdfs:subClassOf hp:LongTermCareServiceCapacity ,
                                            hp:SeniorServiceAccessThing ,
                                            <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass hp:LongTermCareBedPopulation
                                            ] ;
                            rdfs:comment "is a type of LongTermCareServiceCapacity that is also a subclass of i72:Quantity. It represents the total beds (spaces) available for long term care residents." ;
                            rdfs:label "Number of long term care beds" .


###  http://ontology.eil.utoronto.ca/HPCDM/NumberOfLongTermCareBedsAvailable
hp:NumberOfLongTermCareBedsAvailable rdf:type owl:Class ;
                                     rdfs:subClassOf hp:LongTermCareServiceCapacity ,
                                                     hp:SeniorServiceAccessThing ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass hp:NumberOfLongTermCareBeds
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass hp:NumberOfLongTermCareResidents
                                                     ] ;
                                     rdfs:comment "is a type of LongTermCareServiceCapacity that is also a subclass of DifferenceQuantity. It is defined as the difference between the NumberOfBeds and the NumberOfResidents." ;
                                     rdfs:label "Number of long term care beds available" .


###  http://ontology.eil.utoronto.ca/HPCDM/NumberOfLongTermCareResidents
hp:NumberOfLongTermCareResidents rdf:type owl:Class ;
                                 rdfs:subClassOf hp:LongTermCareServiceCapacity ,
                                                 hp:SeniorServiceAccessThing ,
                                                 <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onClass hp:LongTermCareResidentPopulation
                                                 ] ;
                                 rdfs:comment "is a type of LongTermCareServiceCapacity that is also a subclass of i72:Quantity. It represents the total number of residents in a particular long term care residence." ;
                                 rdfs:label "Number of long term care residents" .


###  http://ontology.eil.utoronto.ca/HPCDM/Parcel
hp:Parcel rdf:type owl:Class ;
          rdfs:subClassOf hp:AdministrativeArea ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty hp:createdFromLot ;
                            owl:allValuesFrom hp:Lot
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty hp:ownership ;
                            owl:allValuesFrom [ rdf:type owl:Class ;
                                                owl:unionOf ( org:Organization
                                                              <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Agent/Agent>
                                                            )
                                              ]
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasIdentifier> ;
                            owl:someValuesFrom xsd:string
                          ] ;
          rdfs:comment "A Parcel (sometimes “cadastral parcel”) defines a unit of ownership of some area of land. A Parcel is distinct from a Lot, though they are closely related. A Parcel is referenced when addressing questions of ownership and taxation, whereas Lots are typically referred to when describing land use regulations. Parcels may be “created from” lots when they are registered in the land title system (e.g. when a lot is divided according to a plan) – however, there is not always a 1:1 relationship between the two objects. A Parcel may contain multiple Lots, and a Lot may contain multiple Parcels. It is possible that a Parcel(s) is not wholly contained by a Lot (or vice versa)." .


###  http://ontology.eil.utoronto.ca/HPCDM/ParkPopulation
hp:ParkPopulation rdf:type owl:Class ;
                  rdfs:subClassOf hp:ParkServiceAccessThing ,
                                  <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#defined_by> ;
                                    owl:allValuesFrom gcir:Park
                                  ] .


###  http://ontology.eil.utoronto.ca/HPCDM/ParkService
hp:ParkService rdf:type owl:Class ;
               rdfs:subClassOf hp:ParkServiceAccessThing ,
                               hp:Service ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty hp:hasPlannedCapacity ;
                                 owl:allValuesFrom hp:ParkServiceCapacity
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty hp:providedFromSite ;
                                 owl:allValuesFrom gcir:Park
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                 owl:allValuesFrom hp:ParkServiceCapacity
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                 owl:allValuesFrom hp:ParkServiceCapacity
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                 owl:allValuesFrom hp:ParkServiceCapacity
                               ] ;
               rdfs:comment "represents the service provided by parks such as access to recreation facilities and greenspace." ;
               rdfs:label "Park" ;
               skos:altLabel "Park service" .


###  http://ontology.eil.utoronto.ca/HPCDM/ParkServiceAccessThing
hp:ParkServiceAccessThing rdf:type owl:Class ;
                          rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/ParkServiceCapacity
hp:ParkServiceCapacity rdf:type owl:Class ;
                       rdfs:subClassOf hp:ParkServiceAccessThing ,
                                       [ rdf:type owl:Class ;
                                         owl:unionOf ( hp:QuantityConstraint
                                                       <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                     )
                                       ] ;
                       rdfs:comment "a specialization of i72:Quantity that captures a measure of the capacity of a park service. The isor:13.1 indicator is one quantity that may be used as a measure of capacity at the city level. It can also be used to inform the definition of a comparable property at the individual park level." .


###  http://ontology.eil.utoronto.ca/HPCDM/PassengerThroughputCount
hp:PassengerThroughputCount rdf:type owl:Class ;
                            rdfs:subClassOf hp:TransitAccessThing ,
                                            <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ;
                            rdfs:comment "A measure of the number of passengers moved by the service." .


###  http://ontology.eil.utoronto.ca/HPCDM/PassengerThroughputRate
hp:PassengerThroughputRate rdf:type owl:Class ;
                           rdfs:subClassOf hp:RatioQuantity ,
                                           hp:TransitAccessThing ,
                                           hp:TransitCapacity ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty hp:forLocation ;
                                             owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass CityUnits:Duration
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass hp:PassengerThroughputCount
                                           ] ;
                           rdfs:comment "A Quantity that indicates the volume of passengers moved by the transit system in a particular time period." ;
                           rdfs:label "Passenger throughput rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/Plan
hp:Plan rdf:type owl:Class ;
        rdfs:subClassOf hp:InformationArtifact ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty hp:proposedFor ;
                          owl:allValuesFrom <http://www.w3.org/2006/time#TemporalEntity>
                        ] ;
        rdfs:comment """Refers to an information artifact that contains some specification of a future state. May be proposed or approved. A plan is defined at a general level and may refer various types of artifacts such as planned zoning designations or land divisions, or plans submitted for building construction. 
Note that Plan is a “stub” class. Its definition is not elaborated as it is not currently required for the purposes of this data model.""" .


###  http://ontology.eil.utoronto.ca/HPCDM/PublicTransitService
hp:PublicTransitService rdf:type owl:Class ;
                        rdfs:subClassOf hp:Service ,
                                        hp:TransitAccessThing ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty hp:hasPlannedCapacity ;
                                          owl:allValuesFrom hp:TransitCapacity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty hp:providedFromSite ;
                                          owl:allValuesFrom cdt:TransitStop
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                          owl:allValuesFrom hp:TransitCapacity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                          owl:allValuesFrom hp:TransitCapacity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                          owl:allValuesFrom hp:TransitCapacity
                                        ] ;
                        rdfs:comment "PublicTransitService represents a service that enables the movement of people through publicly accessible routes and vehicles. It may be defined at the city-, region-, or route-level." ;
                        rdfs:label "Public transit" ;
                        skos:altLabel "Public transit service" .


###  http://ontology.eil.utoronto.ca/HPCDM/QuantityAllowance
hp:QuantityAllowance rdf:type owl:Class ;
                     rdfs:subClassOf hp:QuantityConstraint ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty hp:specifiesMaximumFor ;
                                       owl:allValuesFrom om-1:Quantity
                                     ] ;
                     rdfs:comment "A QuantityAllowance is a QuantityConstraint that specifies an allowed amount for the constrained quantity." .


###  http://ontology.eil.utoronto.ca/HPCDM/QuantityConstraint
hp:QuantityConstraint rdf:type owl:Class ;
                      rdfs:subClassOf hp:QuantityConstraintThing ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:constrains ;
                                        owl:allValuesFrom om-1:Quantity
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:definedAtTime ;
                                        owl:allValuesFrom <http://www.w3.org/2006/time#Instant>
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:definedForTime ;
                                        owl:allValuesFrom <http://www.w3.org/2006/time#Interval>
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:definedIn ;
                                        owl:allValuesFrom hp:InformationArtifact
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasValue> ;
                                        owl:allValuesFrom hp:ConstraintSpecification
                                      ] ;
                      rdfs:comment """A QuantityConstraint refers to some restriction on a 21972:Quantity. While quantities are commonly used to describe measured attributes of an object (e.g. area, height), the ISO/IEC 21972 ontology also includes a representation of 21972:Parameters as types of 21972:Quantity. Thus, QuantityConstraints apply not only to attributes of individual objects but to parameters (e.g., minimums, maximums, averages) of object populations. A numerical value that specifies the constraint on the quantity is expressed with the Constraint Specification class.

Note the distinction between a QuantityConstraint and a constraint that is specified on a Quantity class. For example, ISO/IEC 21972 allows for a specification of constraints on types of Quantities – for example, a class such as “Amenity Rating” could be defined such that its associated measures must always be between values of 0 and 5. This is distinct from the specification (Quantity Constraint) that a particular amenity rating(s) should be above 3 (for example).""" .


###  http://ontology.eil.utoronto.ca/HPCDM/QuantityConstraintThing
hp:QuantityConstraintThing rdf:type owl:Class ;
                           rdfs:subClassOf hp:HPCDMThing ;
                           rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/QuantityEquivalence
hp:QuantityEquivalence rdf:type owl:Class ;
                       rdfs:subClassOf hp:QuantityConstraint ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty hp:specifiesValueFor ;
                                         owl:allValuesFrom om-1:Quantity
                                       ] ;
                       rdfs:comment "A QuantityEquivalence is a QuantityConstratint that specifies an exact required amount for the constrained quantity." .


###  http://ontology.eil.utoronto.ca/HPCDM/QuantityRequirement
hp:QuantityRequirement rdf:type owl:Class ;
                       rdfs:subClassOf hp:QuantityConstraint ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty hp:specifiesMinimumFor ;
                                         owl:allValuesFrom om-1:Quantity
                                       ] ;
                       rdfs:comment "A QuantityRequirement is a QuantityConstraint that specifies a minimum amount for the constrained quantity." .


###  http://ontology.eil.utoronto.ca/HPCDM/QuantityThing
hp:QuantityThing rdf:type owl:Class ;
                 rdfs:subClassOf hp:HPCDMThing ;
                 rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/RatioQuantity
hp:RatioQuantity rdf:type owl:Class ;
                 rdfs:subClassOf hp:QuantityThing ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                   owl:allValuesFrom om-1:Quantity
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                   owl:allValuesFrom om-1:Quantity
                                 ] ;
                 rdfs:comment "A type of i72:Quantity that is defined as a ratio of two other quantities. For example, “firefighters per capita” is a ratio of some quantity of a count of firefighters to a count of resident population. Note that RatioQuantity is not currently in ISO/IEC 21972, though it is expected to be proposed in the next revision. If it is added, it is expected that this will be an owl:EquivalentClass." .


###  http://ontology.eil.utoronto.ca/HPCDM/RecreationAreaPopulationRatio
hp:RecreationAreaPopulationRatio rdf:type owl:Class ;
                                 rdfs:subClassOf hp:ParkServiceAccessThing ,
                                                 hp:ParkServiceCapacity ,
                                                 hp:RatioQuantity ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty hp:forLocation ;
                                                   owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                                 ] ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                   owl:hasValue hp:square_metre_per_person
                                                 ] ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onClass hp:ResidentPopulationSize
                                                 ] ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onClass hp:RecreationAreaSum
                                                 ] ;
                                 rdfs:comment "defined similarly to the park area per capita indicator (isor:13.1) in the Global City Indicator Recreation Ontology. It represents a measure of total park area to the population size in a region." ;
                                 rdfs:label "Total park area per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/RecreationAreaSum
hp:RecreationAreaSum rdf:type owl:Class ;
                     rdfs:subClassOf hp:ParkServiceAccessThing ,
                                     <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Sum> ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#parameter_of_var> ;
                                       owl:allValuesFrom [ owl:intersectionOf ( <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Variable>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#has_Name> ;
                                                                                  owl:hasValue "http://ontology.eil.utoronto.ca/HPCDM/hasArea"
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ]
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#sum_of> ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass hp:ParkPopulation
                                     ] ;
                     rdfs:comment "a i72:Sum quantity that represents a sum of the recreation areas (defined with the gcir:hasFloorArea property), in the specified 5087-1:Location." .


###  http://ontology.eil.utoronto.ca/HPCDM/Regulation
hp:Regulation rdf:type owl:Class ;
              rdfs:subClassOf hp:ZoningThing ,
                              opr:Regulation ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:appliesTo ;
                                owl:allValuesFrom hp:AdministrativeArea
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:definedFor ;
                                owl:allValuesFrom hp:AdministrativeArea
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:definedIn ;
                                owl:allValuesFrom [ rdf:type owl:Class ;
                                                    owl:unionOf ( hp:ZoningBylaw
                                                                  hp:ZoningBylawPart
                                                                )
                                                  ]
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:designatesZoningType ;
                                owl:allValuesFrom hp:ZoningType
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:forLandUse ;
                                owl:allValuesFrom hp:LandUse
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:onPopulation ;
                                owl:allValuesFrom <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population>
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:specifiesConstraint ;
                                owl:allValuesFrom hp:QuantityConstraint
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty opr:forZoningType ;
                                owl:allValuesFrom hp:ZoningType
                              ] ;
              rdfs:comment "A specialization of opr:Regulation, a Regulation identifies some requirement or allowance specified (in a bylaw) on how some area(s) of the city may be used and developed. It is defined for some area of land (in some cases the entire city, though often a specific zone). Many regulations specify the application of a zoning types to an area, however they may also define constraints on the attributes of infrastructure (often, buildings) or even on the parcels themselves (e.g., minimum area), independent of a particular zoning type." .


###  http://ontology.eil.utoronto.ca/HPCDM/ResidentPopulation
hp:ResidentPopulation rdf:type owl:Class ;
                      rdfs:subClassOf hp:ServiceAccessThing ,
                                      <http://ontology.eil.utoronto.ca/govstat.owl#Population> ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty Code:definedBy ;
                                        owl:allValuesFrom CityResident:CityResident
                                      ] ;
                      rdfs:comment "the Population of CityResidents (in a particular area)." .


###  http://ontology.eil.utoronto.ca/HPCDM/ResidentPopulationSize
hp:ResidentPopulationSize rdf:type owl:Class ;
                          rdfs:subClassOf hp:ServiceAccessThing ,
                                          <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass hp:ResidentPopulation
                                          ] ;
                          rdfs:comment "represents the number of residents (in a particular area). This class is useful for many types of services because the capacity of city services is often specified as some measure per capita. To represent these types of measures requires the specification of the value as a ratio of some quantity to the population in an area. It is defined as a subclass of i72:Cardinality that is the cardinality of a ResidentPopulation." .


###  http://ontology.eil.utoronto.ca/HPCDM/Resource
hp:Resource rdf:type owl:Class ;
            rdfs:subClassOf hp:ServiceAccessThing ,
                            <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/Resource> ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty hp:hasPlannedCapacity ;
                              owl:allValuesFrom [ rdf:type owl:Class ;
                                                  owl:unionOf ( hp:QuantityConstraint
                                                                om-1:Quantity
                                                              )
                                                ]
                            ] .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolAvailableEnrollmentSpaces
hp:SchoolAvailableEnrollmentSpaces rdf:type owl:Class ;
                                   rdfs:subClassOf hp:DifferenceQuantity ,
                                                   hp:SchoolServiceCapacity ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_1> ;
                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onClass hp:SchoolEnrollmentSpaces
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#term_2> ;
                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onClass hp:SchoolEnrollmentSize
                                                   ] ;
                                   rdfs:comment "a DifferenceQuantity that represents the available spaces for enrollment at a school. It is defined as the difference between" ;
                                   rdfs:label "Available enrollment spaces" .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolEnrollmentPopulation
hp:SchoolEnrollmentPopulation rdf:type owl:Class ;
                              rdfs:subClassOf hp:SchoolServiceAccessThing ,
                                              <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ;
                              rdfs:comment "represents the population of students enrolled at a particular school service (individual school, school grade(s)s, or set of schools depending on the service definition)." ;
                              rdfs:label "Students enrolled" .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolEnrollmentSize
hp:SchoolEnrollmentSize rdf:type owl:Class ;
                        rdfs:subClassOf hp:SchoolServiceCapacity ,
                                        <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass hp:SchoolEnrollmentPopulation
                                        ] ;
                        rdfs:comment "is a SchoolServiceCapacity and an i72:Quantity that represents the number of students enrolled in a school. It may be used as a measure of the school service capacity in use." .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolEnrollmentSpacePopulation
hp:SchoolEnrollmentSpacePopulation rdf:type owl:Class ;
                                   rdfs:subClassOf hp:SchoolServiceAccessThing ,
                                                   <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ;
                                   rdfs:comment "represents the total enrollment spaces for a particular school service." ;
                                   rdfs:label "Enrollment spaces" .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolEnrollmentSpaces
hp:SchoolEnrollmentSpaces rdf:type owl:Class ;
                          rdfs:subClassOf hp:SchoolServiceCapacity ,
                                          <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass hp:SchoolEnrollmentSpacePopulation
                                          ] ;
                          rdfs:comment "is a SchoolServiceCapacity that represents the total number of enrollment spaces at a school. It can be used as a measure of the total school service capacity." .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolService
hp:SchoolService rdf:type owl:Class ;
                 rdfs:subClassOf hp:SchoolServiceAccessThing ,
                                 hp:Service ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty hp:hasPlannedCapacity ;
                                   owl:allValuesFrom hp:SchoolServiceCapacity
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty hp:providedFromSite ;
                                   owl:allValuesFrom hp:SchoolSite
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                   owl:allValuesFrom hp:SchoolServiceCapacity
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                   owl:allValuesFrom hp:SchoolServiceCapacity
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                   owl:allValuesFrom hp:SchoolServiceCapacity
                                 ] ;
                 rdfs:comment "represents the service provided by schools, particularly the delivery of various education programs." ;
                 rdfs:label "School" ;
                 skos:altLabel "School service" .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolServiceAccessThing
hp:SchoolServiceAccessThing rdf:type owl:Class ;
                            rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolServiceCapacity
hp:SchoolServiceCapacity rdf:type owl:Class ;
                         rdfs:subClassOf hp:SchoolServiceAccessThing ,
                                         [ rdf:type owl:Class ;
                                           owl:unionOf ( hp:QuantityConstraint
                                                         <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                       )
                                         ] ;
                         rdfs:comment "a type of i72:Quantity or QuantityConstraint that captures a measure of the capacity of a school service." .


###  http://ontology.eil.utoronto.ca/HPCDM/SchoolSite
hp:SchoolSite rdf:type owl:Class ;
              rdfs:subClassOf hp:SchoolServiceAccessThing ,
                              org:Site ;
              rdfs:comment "a Site (i.e., the facility) where a SchoolService is provided." .


###  http://ontology.eil.utoronto.ca/HPCDM/SecondarySchoolService
hp:SecondarySchoolService rdf:type owl:Class ;
                          rdfs:subClassOf hp:SchoolService .


###  http://ontology.eil.utoronto.ca/HPCDM/SeniorServiceAccessThing
hp:SeniorServiceAccessThing rdf:type owl:Class ;
                            rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/Service
hp:Service rdf:type owl:Class ;
           rdfs:subClassOf hp:ServiceAccessThing ,
                           Change:Manifestation ,
                           <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/CityService/Service> ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:hasPlannedCapacity ;
                             owl:allValuesFrom [ rdf:type owl:Class ;
                                                 owl:unionOf ( hp:QuantityConstraint
                                                               om-1:Quantity
                                                             )
                                               ]
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:hasResource ;
                             owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/Resource>
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:hasServiceRadius ;
                             owl:allValuesFrom CityUnits:Length
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:hasSubService ;
                             owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/CityService/Service>
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:providedFromSite ;
                             owl:allValuesFrom org:Site
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty hp:providedToParcel ;
                             owl:allValuesFrom hp:Parcel
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                             owl:allValuesFrom om-1:Quantity
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                             owl:allValuesFrom [ rdf:type owl:Class ;
                                                 owl:unionOf ( hp:DifferenceQuantity
                                                               hp:QuantityConstraint
                                                             )
                                               ]
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                             owl:allValuesFrom [ rdf:type owl:Class ;
                                                 owl:unionOf ( hp:QuantityConstraint
                                                               om-1:Quantity
                                                             )
                                               ]
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/CityService/hasCatchmentArea> ;
                             owl:allValuesFrom hp:CatchmentArea
                           ] ;
           rdfs:comment "Service defined as a specialization of the city Service class introduced in ISO/IEC 5087-2. It refers, generally, to an activity that is provided to produce some output to its clients. While Services often refer to activities performed or offered by the city, they also include offerings from other organizations such as education services offered by universities or colleges or medical services offered by a pharmacy. The Service class in the HPCDM introduces some additional properties that are important for housing potential use cases. It is also defined as a subclass of 5087-1:Manifestation to capture the changes to the properties of a Service (in particular, its capacity) over time." .


###  http://ontology.eil.utoronto.ca/HPCDM/ServiceAccessThing
hp:ServiceAccessThing rdf:type owl:Class ;
                      rdfs:subClassOf hp:HPCDMThing ;
                      rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/SolidWasteService
hp:SolidWasteService rdf:type owl:Class ;
                     rdfs:subClassOf hp:Service ,
                                     hp:SolidWasteServiceAccessThing ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty hp:hasPlannedCapacity ;
                                       owl:allValuesFrom hp:SolidWasteServiceCapacity
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                       owl:allValuesFrom hp:SolidWasteServiceCapacity
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                       owl:allValuesFrom hp:SolidWasteServiceCapacity
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                       owl:allValuesFrom hp:SolidWasteServiceCapacity
                                     ] ;
                     rdfs:comment "refers to service that collects solid waste (garbage, recycling, organics) from homes." ;
                     rdfs:label "Solid waste" ;
                     skos:altLabel "Solid waste service" .


###  http://ontology.eil.utoronto.ca/HPCDM/SolidWasteServiceAccessThing
hp:SolidWasteServiceAccessThing rdf:type owl:Class ;
                                rdfs:subClassOf hp:HPCDMThing ;
                                rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/SolidWasteServiceCapacity
hp:SolidWasteServiceCapacity rdf:type owl:Class ;
                             rdfs:subClassOf hp:SolidWasteServiceAccessThing ,
                                             [ rdf:type owl:Class ;
                                               owl:unionOf ( hp:QuantityConstraint
                                                             om-1:Quantity
                                                           )
                                             ] ;
                             rdfs:comment "a i72:Quantity or QuantityConstraint that defines a measure of the service’s use/availability. This capacity can be captured in different ways, for example based on rates of collection or total waste volume." .


###  http://ontology.eil.utoronto.ca/HPCDM/SupermarketCount
hp:SupermarketCount rdf:type owl:Class ;
                    rdfs:subClassOf hp:FoodServiceAccessThing ,
                                    <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#cardinality_of> ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass hp:SupermarketPopulation
                                    ] ;
                    rdfs:comment """a subclass of SupermarketServiceCapacity. Describes the capacity of a supermarket as the ratio of the number of supermarkets to the population in its catchment area. 
is an i72:Cardinality quantity that represents the number of supermarkets (i.e., the size of the supermarket population) in the location of interest. It is a i72:cardinality_of some SupermarketPopulation.""" .


###  http://ontology.eil.utoronto.ca/HPCDM/SupermarketPopulation
hp:SupermarketPopulation rdf:type owl:Class ;
                         rdfs:subClassOf hp:FoodServiceAccessThing ,
                                         <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Population> ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#defined_by> ;
                                           owl:allValuesFrom hp:SupermarketSite
                                         ] ;
                         rdfs:comment "is an i72:Population quantity that captures the population of supermarkets in a particular area. It is i72:defined_by the SupermarketSite class." .


###  http://ontology.eil.utoronto.ca/HPCDM/SupermarketService
hp:SupermarketService rdf:type owl:Class ;
                      rdfs:subClassOf hp:FoodServiceAccessThing ,
                                      hp:Service ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:hasPlannedCapacity ;
                                        owl:allValuesFrom hp:SupermarketServiceCapacity
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty hp:providedFromSite ;
                                        owl:allValuesFrom hp:SupermarketSite
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                        owl:allValuesFrom hp:SupermarketServiceCapacity
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                        owl:allValuesFrom hp:SupermarketServiceCapacity
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                        owl:allValuesFrom hp:SupermarketServiceCapacity
                                      ] ;
                      rdfs:comment "the sale of goods (food, in particular) to the public from a supermarket" ;
                      rdfs:label "Supermarket" ;
                      skos:altLabel "Supermarket service" .


###  http://ontology.eil.utoronto.ca/HPCDM/SupermarketServiceCapacity
hp:SupermarketServiceCapacity rdf:type owl:Class ;
                              rdfs:subClassOf hp:FoodServiceAccessThing ,
                                              [ rdf:type owl:Class ;
                                                owl:unionOf ( hp:QuantityConstraint
                                                              <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                            )
                                              ] ;
                              rdfs:comment "a specialization of i72:Quantity that captures a measure of the capacity of a supermarket service." .


###  http://ontology.eil.utoronto.ca/HPCDM/SupermarketSite
hp:SupermarketSite rdf:type owl:Class ;
                   rdfs:subClassOf hp:FoodServiceAccessThing ,
                                   org:Site ;
                   rdfs:comment "refers to the physical place (i.e., the supermarket) where the service is provided." .


###  http://ontology.eil.utoronto.ca/HPCDM/SupermarketsPopulationRatio
hp:SupermarketsPopulationRatio rdf:type owl:Class ;
                               rdfs:subClassOf hp:FoodServiceAccessThing ,
                                               hp:RatioQuantity ,
                                               hp:SupermarketServiceCapacity ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty hp:forLocation ;
                                                 owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasUnit> ;
                                                 owl:hasValue <http://ontology.eil.utoronto.ca/ISO21972/iso21972#population_ratio_unit>
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass hp:ResidentPopulationSize
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass hp:SupermarketCount
                                               ] ;
                               rdfs:comment "a subclass of SupermarketServiceCapacity. Describes the capacity of a supermarket as the ratio of the number of supermarkets to the population in its catchment area." ;
                               rdfs:label "Number of supermarkets per capita" .


###  http://ontology.eil.utoronto.ca/HPCDM/TotalWasteProcessedMass
hp:TotalWasteProcessedMass rdf:type owl:Class ;
                           rdfs:subClassOf hp:SolidWasteServiceAccessThing ,
                                           CityUnits:Mass ;
                           rdfs:comment "a measure of (the mass of) waste processed by the solid waste service during some time period." .


###  http://ontology.eil.utoronto.ca/HPCDM/TransitAccessThing
hp:TransitAccessThing rdf:type owl:Class ;
                      rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/TransitCapacity
hp:TransitCapacity rdf:type owl:Class ;
                   rdfs:subClassOf hp:TransitAccessThing ,
                                   [ rdf:type owl:Class ;
                                     owl:unionOf ( hp:QuantityConstraint
                                                   <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                                                 )
                                   ] ;
                   rdfs:comment "a measure of how much can be transported by the public transit service." .


###  http://ontology.eil.utoronto.ca/HPCDM/TransportationCapacity
hp:TransportationCapacity rdf:type owl:Class ;
                          rdfs:subClassOf hp:TransportationServiceAccessThing ,
                                          [ rdf:type owl:Class ;
                                            owl:unionOf ( hp:QuantityConstraint
                                                          om-1:Quantity
                                                        )
                                          ] ;
                          rdfs:comment "a generalized representation of the capacity of the service (current/total/available). It is a subclass of i72:Quantity or QuantityConstraint. Note that TransportationCapacity often directly correlates with the capacities of a TransportationSite (e.g., a road segment) as these elements are the key resources that enable transportation on the network." .


###  http://ontology.eil.utoronto.ca/HPCDM/TransportationNetworkService
hp:TransportationNetworkService rdf:type owl:Class ;
                                rdfs:subClassOf hp:Service ,
                                                hp:TransportationServiceAccessThing ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty hp:hasPlannedCapacity ;
                                                  owl:allValuesFrom hp:TransportationCapacity
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty hp:providedFromSite ;
                                                  owl:allValuesFrom hp:TransportationSite
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                                  owl:allValuesFrom hp:TransportationCapacity
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                                  owl:allValuesFrom hp:TransportationCapacity
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                                  owl:allValuesFrom hp:TransportationCapacity
                                                ] ;
                                rdfs:comment "TransportationNetworkService refers to the service of enabling the movement of people and goods" ;
                                rdfs:label "Transportation network" ;
                                skos:altLabel "Transportation network service" .


###  http://ontology.eil.utoronto.ca/HPCDM/TransportationServiceAccessThing
hp:TransportationServiceAccessThing rdf:type owl:Class ;
                                    rdfs:subClassOf hp:HPCDMThing .


###  http://ontology.eil.utoronto.ca/HPCDM/TransportationSite
hp:TransportationSite rdf:type owl:Class ;
                      rdfs:subClassOf hp:TransportationServiceAccessThing ,
                                      [ rdf:type owl:Class ;
                                        owl:unionOf ( TransInfra:TravelledWay
                                                      TransInfra:TravelledWayLink
                                                      TransInfra:TravelledWaySegment
                                                    )
                                      ] ;
                      rdfs:comment "defined as a subclass of 5087-2:TravelledWaySegment or 5087-2:TravelledWayLink or 5087-2:TravelledWay. As defined in ISO/IEC 5087-2, TravelledWay, TravelledWayLink, and TravelledWaySegment classes define the transportation network at varying levels of granularity (from highest to lowest, respectively). The classes refer to the physical infrastructure where the transportation takes place. This includes road networks but also footpaths and bicycle paths. TransportationSite is a subclass of 5087-2:TravelledWaySegment (the superclass that includes 5087-2:RoadSegments). Note that 5087-2:TravelledWaySegment has a property 5087-2:networkType that allows for the specification of the mode of travel permitted on the segment." .


###  http://ontology.eil.utoronto.ca/HPCDM/UseQuantum
hp:UseQuantum rdf:type owl:Class ;
              rdfs:subClassOf hp:ZoningThing ,
                              oz:UseQuantum ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:forLandUse ;
                                owl:allValuesFrom hp:LandUse
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#hasValue> ;
                                owl:allValuesFrom <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Quantity>
                              ] ;
              rdfs:comment """A Use Quantum corresponds to the amount of use permitted (minimum or maximum). Instead of defining a Use Quantum exclusively for an individual Land Use object, in the HPCDM, a Use Quantum is defined according to some ZoningType and then associated to a type of Land Use.
It is defined as a specialization of oz:UseQuantum (which is only defined in the context of oz:LandUse.""" .


###  http://ontology.eil.utoronto.ca/HPCDM/Utility
hp:Utility rdf:type owl:Class ;
           rdfs:subClassOf hp:Service ;
           rdfs:comment "a subclass of Service defined to identify the category of essential services delivered through physical infrastructure. Examples of utility services include electricity and water." ;
           rdfs:label "Utility" ;
           skos:altLabel "Utility service" .


###  http://ontology.eil.utoronto.ca/HPCDM/VehicleThroughputCount
hp:VehicleThroughputCount rdf:type owl:Class ;
                          rdfs:subClassOf hp:TransportationServiceAccessThing ,
                                          <http://ontology.eil.utoronto.ca/ISO21972/iso21972#Cardinality> .


###  http://ontology.eil.utoronto.ca/HPCDM/VehicleThroughputRate
hp:VehicleThroughputRate rdf:type owl:Class ;
                         rdfs:subClassOf hp:RatioQuantity ,
                                         hp:TransportationCapacity ,
                                         hp:TransportationServiceAccessThing ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty hp:forLocation ;
                                           owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                           owl:onClass CityUnits:Duration
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                           owl:onClass hp:VehicleThroughputCount
                                         ] ;
                         rdfs:comment "a kind of TransportationCapacity. It is a Ratio Quantity of the number of vehicles that pass through the network to the duration of time that the travel takes place. It is a possible measure of the in use capacity of a TransportationNetworkService. (consider: alternatives could include, e.g. bicycle or pedestrian)." ;
                         rdfs:label "Vehicle throughput rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/WasteProcessingRate
hp:WasteProcessingRate rdf:type owl:Class ;
                       rdfs:subClassOf hp:RatioQuantity ,
                                       hp:SolidWasteServiceCapacity ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty hp:forLocation ;
                                         owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass CityUnits:Duration
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass hp:TotalWasteProcessedMass
                                       ] ;
                       rdfs:comment "a type of SolidWasteServiceCapacity. This RatioQuantity specifies the rate at which waste is processed by the service (often, in tonnes per year). It is a possible measure of the capacity in use of a service. It is a ratio of TotalWasteProcessedMass to the 5087-1:Duration (over which it is processed)." ;
                       rdfs:label "Waste processing rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/WastewaterService
hp:WastewaterService rdf:type owl:Class ;
                     rdfs:subClassOf hp:Utility ,
                                     hp:WastewaterServiceAccessThing ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty hp:hasPlannedCapacity ;
                                       owl:allValuesFrom hp:WastewaterServiceCapacity
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                       owl:allValuesFrom hp:WastewaterServiceCapacity
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                       owl:allValuesFrom hp:WastewaterServiceCapacity
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                       owl:allValuesFrom hp:WastewaterServiceCapacity
                                     ] ;
                     rdfs:comment "refers to the service that processes wastewater from homes and businesses. It is defined as a type of Utility" .


###  http://ontology.eil.utoronto.ca/HPCDM/WastewaterServiceAccessThing
hp:WastewaterServiceAccessThing rdf:type owl:Class ;
                                rdfs:subClassOf hp:HPCDMThing ;
                                rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/WastewaterServiceCapacity
hp:WastewaterServiceCapacity rdf:type owl:Class ;
                             rdfs:subClassOf hp:WastewaterServiceAccessThing ,
                                             [ rdf:type owl:Class ;
                                               owl:unionOf ( hp:QuantityConstraint
                                                             om-1:Quantity
                                                           )
                                             ] ;
                             rdfs:comment "a measure how much wastewater the service can process (total, in use, or available)." .


###  http://ontology.eil.utoronto.ca/HPCDM/WaterDistributionCapacity
hp:WaterDistributionCapacity rdf:type owl:Class ;
                             rdfs:subClassOf hp:WaterServiceAccessThing ,
                                             [ rdf:type owl:Class ;
                                               owl:unionOf ( hp:QuantityConstraint
                                                             om-1:Quantity
                                                           )
                                             ] ;
                             rdfs:comment "a measure of the water service’s capacity (total, in use, or available)." .


###  http://ontology.eil.utoronto.ca/HPCDM/WaterDistributionRate
hp:WaterDistributionRate rdf:type owl:Class ;
                         rdfs:subClassOf hp:RatioQuantity ,
                                         hp:WaterDistributionCapacity ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty hp:forLocation ;
                                           owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                           owl:onClass CityUnits:Duration
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                           owl:onClass hp:WaterDistributionVolume
                                         ] ;
                         rdfs:comment "a type of WaterDistributionCapacity. It is a i72:Quantity that defines the total volume of water distributed over some time period. It is a possible measure of the capacity in-use of the water service." ;
                         rdfs:label "Distribution rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/WaterDistributionVolume
hp:WaterDistributionVolume rdf:type owl:Class ;
                           rdfs:subClassOf hp:WaterServiceAccessThing ,
                                           CityUnits:Volume ;
                           rdfs:comment "a measure of the total amount of water distributed during some time period." .


###  http://ontology.eil.utoronto.ca/HPCDM/WaterProcessedVolume
hp:WaterProcessedVolume rdf:type owl:Class ;
                        rdfs:subClassOf hp:WastewaterServiceAccessThing ,
                                        CityUnits:Volume ;
                        rdfs:comment "a measure of the total amount of water processed during some time period." .


###  http://ontology.eil.utoronto.ca/HPCDM/WaterProcessingRate
hp:WaterProcessingRate rdf:type owl:Class ;
                       rdfs:subClassOf hp:RatioQuantity ,
                                       hp:WastewaterServiceCapacity ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty hp:forLocation ;
                                         owl:allValuesFrom <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/Location>
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#denominator> ;
                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass CityUnits:Duration
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://ontology.eil.utoronto.ca/ISO21972/iso21972#numerator> ;
                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass hp:WaterProcessedVolume
                                       ] ;
                       rdfs:comment "a type of WastewaterServiceCapacity. It is a i72:Quantity that defines the total volume of water processed over some time period. It is a possible measure of the actual or available capacity of the water service." ;
                       rdfs:label "Processing rate" .


###  http://ontology.eil.utoronto.ca/HPCDM/WaterService
hp:WaterService rdf:type owl:Class ;
                rdfs:subClassOf hp:Utility ,
                                hp:WaterServiceAccessThing ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty hp:hasPlannedCapacity ;
                                  owl:allValuesFrom hp:WaterDistributionCapacity
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/capacityInUse> ;
                                  owl:allValuesFrom hp:WaterDistributionCapacity
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasAvailableCapacity> ;
                                  owl:allValuesFrom hp:WaterDistributionCapacity
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/hasCapacity> ;
                                  owl:allValuesFrom hp:WaterDistributionCapacity
                                ] ;
                rdfs:comment "refers to the service that provides water to homes and businesses. It is defined as a Utility." .


###  http://ontology.eil.utoronto.ca/HPCDM/WaterServiceAccessThing
hp:WaterServiceAccessThing rdf:type owl:Class ;
                           rdfs:subClassOf hp:HPCDMThing ;
                           rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/Watershed
hp:Watershed rdf:type owl:Class ;
             rdfs:subClassOf hp:EnvironmentalRiskThing .


###  http://ontology.eil.utoronto.ca/HPCDM/ZoningBylaw
hp:ZoningBylaw rdf:type owl:Class ;
               rdfs:subClassOf hp:ZoningThing ,
                               <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Bylaw/Bylaw> ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty hp:definesRegulation ;
                                 owl:allValuesFrom hp:Regulation
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty hp:definesZoningType ;
                                 owl:allValuesFrom hp:ZoningType
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/hasProperPart> ;
                                 owl:allValuesFrom hp:ZoningBylawPart
                               ] ;
               rdfs:comment "Bylaws are defined in the Bylaw Pattern in ISO/IEC 5087-2, and this representation is extended in the HPCDM to more precisely define zoning bylaws and the ways in which they influence the housing potential of different areas in the city. Zoning bylaws specify land use restrictions but also define constraints on the attributes of the parcels and the infrastructure they contain." .


###  http://ontology.eil.utoronto.ca/HPCDM/ZoningBylawPart
hp:ZoningBylawPart rdf:type owl:Class ;
                   rdfs:subClassOf hp:ZoningThing ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/hasProperPart> ;
                                     owl:allValuesFrom hp:ZoningBylawPart
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasDescription> ;
                                     owl:allValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasIdentifier> ;
                                     owl:allValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasName> ;
                                     owl:allValuesFrom xsd:string
                                   ] ;
                   rdfs:comment "The identification of a part within a Zoning Bylaw is important to allow for more precise references. ZoningBylawPart provides a generalization of the more specific types of parts defined in ISO/IEC 5087-2 (e.g., Clause, Definition). A part could be a chapter, a section, a definition, or even an arbitrary selection of (continuous) lines within the text." .


###  http://ontology.eil.utoronto.ca/HPCDM/ZoningThing
hp:ZoningThing rdf:type owl:Class ;
               rdfs:subClassOf hp:HPCDMThing ;
               rdfs:comment "Not a class in the model formalization. Added for organizational purposes only." .


###  http://ontology.eil.utoronto.ca/HPCDM/ZoningType
hp:ZoningType rdf:type owl:Class ;
              rdfs:subClassOf hp:ZoningThing ,
                              oz:ZoningType ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:definedIn ;
                                owl:allValuesFrom [ rdf:type owl:Class ;
                                                    owl:unionOf ( hp:ZoningBylaw
                                                                  hp:ZoningBylawPart
                                                                )
                                                  ]
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:definesZoningException ;
                                owl:allValuesFrom hp:Regulation
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:hasMaxUseQuantum ;
                                owl:allValuesFrom hp:UseQuantum
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:hasMinUseQuantum ;
                                owl:allValuesFrom hp:UseQuantum
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty hp:subZoningType ;
                                owl:allValuesFrom hp:ZoningType
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty oz:allowsUse ;
                                owl:allValuesFrom hp:LandUse
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty oz:doesNotAllowUse ;
                                owl:allValuesFrom hp:LandUse
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty oz:mayAllowUse ;
                                owl:allValuesFrom hp:LandUse
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasDescription> ;
                                owl:allValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasIdentifier> ;
                                owl:allValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/hasName> ;
                                owl:allValuesFrom xsd:string
                              ] ;
              rdfs:comment """A ZoningType defines various combinations (and amounts) of land use (e.g. Residential, Commercial Residential, Open Space) permitted in a particular area. They are also used as the basis for other regulations – for example, a series of regulations on lot size, density, building height and so on may be defined for a particular zoning type. 
It is a specialization of oz:ZoningType as it introduces additional properties on Zoning Type objects such as use quantums and sub zoning types.""" .


###  http://ontology.eil.utoronto.ca/govstat.owl#Parameter
<http://ontology.eil.utoronto.ca/govstat.owl#Parameter> rdf:type owl:Class .


###  http://ontology.eil.utoronto.ca/govstat.owl#Population
<http://ontology.eil.utoronto.ca/govstat.owl#Population> rdf:type owl:Class .


###  http://www.theworldavatar.com/ontology/ontoplanningregulation/OntoPlanningRegulation.owl#Regulation
opr:Regulation rdf:type owl:Class ;
               rdfs:comment "Added to generalize the concept of URARegulation, based on conversation with OPR authors and confirmation of intent to update the ontology to include this general class." .


###  http://www.theworldavatar.com/ontoplanningregulations/OntoPlanningRegulations.owl#URARegulation
<http://www.theworldavatar.com/ontoplanningregulations/OntoPlanningRegulations.owl#URARegulation> rdfs:subClassOf opr:Regulation .


###  http://www.wurvoc.org/vocabularies/om-1.8/Quantity
om-1:Quantity rdf:type owl:Class .


###  http://www.wurvoc.org/vocabularies/om-1.8/Unit_of_measure
om-1:Unit_of_measure rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://ontology.eil.utoronto.ca/HPCDM/avg_inpatients_daily_per_bed
